{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.94,
      "to": 3.38,
      "sid": 1,
      "location": 2,
      "content": "房地产盘面异动是黎明前的曙光",
      "music": 0.0
    },
    {
      "from": 3.38,
      "to": 4.98,
      "sid": 2,
      "location": 2,
      "content": "还只不过是昙花一现",
      "music": 0.0
    },
    {
      "from": 4.98,
      "to": 6.52,
      "sid": 3,
      "location": 2,
      "content": "本周星期五收盘前",
      "music": 0.0
    },
    {
      "from": 6.52,
      "to": 8.76,
      "sid": 4,
      "location": 2,
      "content": "高盛发布了一份很详细的研究报告",
      "music": 0.0
    },
    {
      "from": 8.76,
      "to": 11.479,
      "sid": 5,
      "location": 2,
      "content": "标题叫提前布局股价反弹",
      "music": 0.0
    },
    {
      "from": 11.479,
      "to": 12.979,
      "sid": 6,
      "location": 2,
      "content": "市场已经反映了什么",
      "music": 0.0
    },
    {
      "from": 12.979,
      "to": 15.079,
      "sid": 7,
      "location": 2,
      "content": "研报用一套非常系统的分析框架",
      "music": 0.0
    },
    {
      "from": 15.079,
      "to": 16.58,
      "sid": 8,
      "location": 2,
      "content": "从人口收入",
      "music": 0.0
    },
    {
      "from": 16.58,
      "to": 19.04,
      "sid": 9,
      "location": 2,
      "content": "购买力供应这四个维度去判断",
      "music": 0.0
    },
    {
      "from": 19.04,
      "to": 20.48,
      "sid": 10,
      "location": 2,
      "content": "哪些城市会先好起来",
      "music": 0.0
    },
    {
      "from": 20.48,
      "to": 21.92,
      "sid": 11,
      "location": 2,
      "content": "以及如果真的好转了",
      "music": 0.0
    },
    {
      "from": 21.92,
      "to": 23.549,
      "sid": 12,
      "location": 2,
      "content": "会对市场产生多大影响",
      "music": 0.0
    },
    {
      "from": 23.549,
      "to": 24.929,
      "sid": 13,
      "location": 2,
      "content": "欢迎来到调研现场",
      "music": 0.0
    },
    {
      "from": 24.929,
      "to": 27.39,
      "sid": 14,
      "location": 2,
      "content": "接下来我们将逐页拆解研报",
      "music": 0.0
    },
    {
      "from": 27.39,
      "to": 29.27,
      "sid": 15,
      "location": 2,
      "content": "首先是研报的第一部分",
      "music": 0.0
    },
    {
      "from": 29.27,
      "to": 31.24,
      "sid": 16,
      "location": 2,
      "content": "高盛给出的核心观点是",
      "music": 0.0
    },
    {
      "from": 31.24,
      "to": 32.66,
      "sid": 17,
      "location": 2,
      "content": "从历史经验看",
      "music": 0.0
    },
    {
      "from": 32.66,
      "to": 34.7,
      "sid": 18,
      "location": 2,
      "content": "股市总是抢跑楼市",
      "music": 0.0
    },
    {
      "from": 34.7,
      "to": 37.28,
      "sid": 19,
      "location": 2,
      "content": "报告里回顾了美国和日本的历史",
      "music": 0.0
    },
    {
      "from": 37.28,
      "to": 38.44,
      "sid": 20,
      "location": 2,
      "content": "过去几十年",
      "music": 0.0
    },
    {
      "from": 38.44,
      "to": 40.7,
      "sid": 21,
      "location": 2,
      "content": "每次房地产周期见底之前",
      "music": 0.0
    },
    {
      "from": 40.7,
      "to": 44.12,
      "sid": 22,
      "location": 2,
      "content": "房地产公司的股票都会先于房价开始上涨",
      "music": 0.0
    },
    {
      "from": 44.12,
      "to": 45.07,
      "sid": 23,
      "location": 2,
      "content": "在美国",
      "music": 0.0
    },
    {
      "from": 45.07,
      "to": 45.79,
      "sid": 24,
      "location": 2,
      "content": "房产股",
      "music": 0.0
    },
    {
      "from": 45.79,
      "to": 48.55,
      "sid": 25,
      "location": 2,
      "content": "一般在房价真正见底之前的一到两个季度",
      "music": 0.0
    },
    {
      "from": 48.55,
      "to": 50.23,
      "sid": 26,
      "location": 2,
      "content": "就率先触底反弹了",
      "music": 0.0
    },
    {
      "from": 50.23,
      "to": 51.19,
      "sid": 27,
      "location": 2,
      "content": "也就是说",
      "music": 0.0
    },
    {
      "from": 51.19,
      "to": 54.35,
      "sid": 28,
      "location": 2,
      "content": "当大家还在担心房价会不会继续跌的时候",
      "music": 0.0
    },
    {
      "from": 54.35,
      "to": 57.05,
      "sid": 29,
      "location": 2,
      "content": "股市里的聪明钱已经开始进场了",
      "music": 0.0
    },
    {
      "from": 57.05,
      "to": 58.79,
      "sid": 30,
      "location": 2,
      "content": "在日本就更夸张了",
      "music": 0.0
    },
    {
      "from": 62.13,
      "to": 63.67,
      "sid": 31,
      "location": 2,
      "content": "房价跌了很多年",
      "music": 0.0
    },
    {
      "from": 63.67,
      "to": 66.43,
      "sid": 32,
      "location": 2,
      "content": "但日本的一些大型房地产公司的股票",
      "music": 0.0
    },
    {
      "from": 66.43,
      "to": 69.57,
      "sid": 33,
      "location": 2,
      "content": "比房价复苏提前了好几年就开始上涨",
      "music": 0.0
    },
    {
      "from": 69.57,
      "to": 70.49,
      "sid": 34,
      "location": 2,
      "content": "为什么",
      "music": 0.0
    },
    {
      "from": 70.49,
      "to": 72.62,
      "sid": 35,
      "location": 2,
      "content": "因为股市看的是预期",
      "music": 0.0
    },
    {
      "from": 72.62,
      "to": 75.3,
      "sid": 36,
      "location": 2,
      "content": "当市场判断最坏的时候已经过去",
      "music": 0.0
    },
    {
      "from": 75.3,
      "to": 77.34,
      "sid": 37,
      "location": 2,
      "content": "未来哪怕只是不再恶化",
      "music": 0.0
    },
    {
      "from": 77.34,
      "to": 79.2,
      "sid": 38,
      "location": 2,
      "content": "股价就可能先涨起来",
      "music": 0.0
    },
    {
      "from": 79.2,
      "to": 82.06,
      "sid": 39,
      "location": 2,
      "content": "高盛用了一个很形象的词抢跑",
      "music": 0.0
    },
    {
      "from": 82.06,
      "to": 84.52,
      "sid": 40,
      "location": 2,
      "content": "那抢跑之后能涨多少呢",
      "music": 0.0
    },
    {
      "from": 84.52,
      "to": 85.57,
      "sid": 41,
      "location": 2,
      "content": "报告里说",
      "music": 0.0
    },
    {
      "from": 85.57,
      "to": 88.49,
      "sid": 42,
      "location": 2,
      "content": "在美国的几次房价复苏周期中",
      "music": 0.0
    },
    {
      "from": 88.49,
      "to": 91.789,
      "sid": 43,
      "location": 2,
      "content": "房产股的平均市净率差不多翻了一倍",
      "music": 0.0
    },
    {
      "from": 91.789,
      "to": 94.909,
      "sid": 44,
      "location": 2,
      "content": "在日本2000年之后的几次复苏中",
      "music": 0.0
    },
    {
      "from": 98.8,
      "to": 100.75,
      "sid": 45,
      "location": 2,
      "content": "这背后的原因也很简单",
      "music": 0.0
    },
    {
      "from": 100.75,
      "to": 101.81,
      "sid": 46,
      "location": 2,
      "content": "房价一涨",
      "music": 0.0
    },
    {
      "from": 101.81,
      "to": 103.55,
      "sid": 47,
      "location": 2,
      "content": "开发商的利润率就提高了",
      "music": 0.0
    },
    {
      "from": 103.55,
      "to": 105.37,
      "sid": 48,
      "location": 2,
      "content": "净资产收益率跟着上升",
      "music": 0.0
    },
    {
      "from": 105.37,
      "to": 107.73,
      "sid": 49,
      "location": 2,
      "content": "同时市场觉得风险降低了",
      "music": 0.0
    },
    {
      "from": 107.73,
      "to": 109.92,
      "sid": 50,
      "location": 2,
      "content": "对回报的要求反而下降了",
      "music": 0.0
    },
    {
      "from": 109.92,
      "to": 111.7,
      "sid": 51,
      "location": 2,
      "content": "一个上升一个下降",
      "music": 0.0
    },
    {
      "from": 111.7,
      "to": 113.4,
      "sid": 52,
      "location": 2,
      "content": "中间的差值拉大",
      "music": 0.0
    },
    {
      "from": 113.4,
      "to": 115.199,
      "sid": 53,
      "location": 2,
      "content": "股价自然就会大涨",
      "music": 0.0
    },
    {
      "from": 115.199,
      "to": 116.039,
      "sid": 54,
      "location": 2,
      "content": "打个比方",
      "music": 0.0
    },
    {
      "from": 116.039,
      "to": 117.5,
      "sid": 55,
      "location": 2,
      "content": "这就好比一家面包店",
      "music": 0.0
    },
    {
      "from": 117.5,
      "to": 119.2,
      "sid": 56,
      "location": 2,
      "content": "以前一个面包卖五块钱",
      "music": 0.0
    },
    {
      "from": 119.2,
      "to": 120.86,
      "sid": 57,
      "location": 2,
      "content": "成本四块赚一块",
      "music": 0.0
    },
    {
      "from": 120.86,
      "to": 122.52,
      "sid": 58,
      "location": 2,
      "content": "现在面包能卖六块了",
      "music": 0.0
    },
    {
      "from": 122.52,
      "to": 124.57,
      "sid": 59,
      "location": 2,
      "content": "成本还是四块赚两块",
      "music": 0.0
    },
    {
      "from": 124.57,
      "to": 125.79,
      "sid": 60,
      "location": 2,
      "content": "利润直接翻倍",
      "music": 0.0
    },
    {
      "from": 125.79,
      "to": 128.05,
      "sid": 61,
      "location": 2,
      "content": "而且大家觉得这家店生意稳了",
      "music": 0.0
    },
    {
      "from": 128.05,
      "to": 129.91,
      "sid": 62,
      "location": 2,
      "content": "愿意给他更高的估值",
      "music": 0.0
    },
    {
      "from": 129.91,
      "to": 131.69,
      "sid": 63,
      "location": 2,
      "content": "股价自然就上去了",
      "music": 0.0
    },
    {
      "from": 131.69,
      "to": 133.77,
      "sid": 64,
      "location": 2,
      "content": "所以高盛的结论是",
      "music": 0.0
    },
    {
      "from": 133.77,
      "to": 136.99,
      "sid": 65,
      "location": 2,
      "content": "如果你想判断楼市什么时候真正回暖",
      "music": 0.0
    },
    {
      "from": 136.99,
      "to": 139.23,
      "sid": 66,
      "location": 2,
      "content": "盯住房地产股票的走势",
      "music": 0.0
    },
    {
      "from": 139.23,
      "to": 141.31,
      "sid": 67,
      "location": 2,
      "content": "往往能提前获得信号",
      "music": 0.0
    },
    {
      "from": 141.31,
      "to": 143.399,
      "sid": 68,
      "location": 2,
      "content": "那这次呢报告写到",
      "music": 0.0
    },
    {
      "from": 143.399,
      "to": 145.939,
      "sid": 69,
      "location": 2,
      "content": "从今年3月底到5月27日",
      "music": 0.0
    },
    {
      "from": 145.939,
      "to": 148.64,
      "sid": 70,
      "location": 2,
      "content": "他们跟踪了一批中国房地产公司",
      "music": 0.0
    },
    {
      "from": 148.64,
      "to": 151.0,
      "sid": 71,
      "location": 2,
      "content": "股价平均反弹了6%",
      "music": 0.0
    },
    {
      "from": 151.0,
      "to": 152.72,
      "sid": 72,
      "location": 2,
      "content": "其中几家比较大的央企",
      "music": 0.0
    },
    {
      "from": 152.72,
      "to": 155.579,
      "sid": 73,
      "location": 2,
      "content": "开发商平均反弹了17%",
      "music": 0.0
    },
    {
      "from": 155.579,
      "to": 158.219,
      "sid": 74,
      "location": 2,
      "content": "个别公司甚至涨了30%左右",
      "music": 0.0
    },
    {
      "from": 158.219,
      "to": 159.42,
      "sid": 75,
      "location": 2,
      "content": "问题来了",
      "music": 0.0
    },
    {
      "from": 159.42,
      "to": 163.2,
      "sid": 76,
      "location": 2,
      "content": "这次反弹到底是跟过去一样昙花一现",
      "music": 0.0
    },
    {
      "from": 163.2,
      "to": 165.31,
      "sid": 77,
      "location": 2,
      "content": "还是真的有基本面支撑",
      "music": 0.0
    },
    {
      "from": 165.31,
      "to": 167.71,
      "sid": 78,
      "location": 2,
      "content": "接下来就要说到报告的核心了",
      "music": 0.0
    },
    {
      "from": 167.71,
      "to": 168.8,
      "sid": 79,
      "location": 2,
      "content": "研报指出",
      "music": 0.0
    },
    {
      "from": 168.8,
      "to": 172.38,
      "sid": 80,
      "location": 2,
      "content": "通过四根支柱去判断城市房价基本面",
      "music": 0.0
    },
    {
      "from": 172.38,
      "to": 174.66,
      "sid": 81,
      "location": 2,
      "content": "以及哪些城市会先复苏",
      "music": 0.0
    },
    {
      "from": 174.66,
      "to": 178.24,
      "sid": 82,
      "location": 2,
      "content": "高盛设计了一套叫四支柱的评估框架",
      "music": 0.0
    },
    {
      "from": 178.24,
      "to": 181.859,
      "sid": 83,
      "location": 2,
      "content": "这四个支柱分别是一人口流入",
      "music": 0.0
    },
    {
      "from": 181.859,
      "to": 184.379,
      "sid": 84,
      "location": 2,
      "content": "年轻人还愿不愿意去这个城市",
      "music": 0.0
    },
    {
      "from": 184.379,
      "to": 186.23,
      "sid": 85,
      "location": 2,
      "content": "二收入增长",
      "music": 0.0
    },
    {
      "from": 186.23,
      "to": 188.41,
      "sid": 86,
      "location": 2,
      "content": "这个城市的企业赚不赚钱",
      "music": 0.0
    },
    {
      "from": 188.41,
      "to": 190.18,
      "sid": 87,
      "location": 2,
      "content": "老百姓工资涨不涨",
      "music": 0.0
    },
    {
      "from": 190.18,
      "to": 191.82,
      "sid": 88,
      "location": 2,
      "content": "三购买力",
      "music": 0.0
    },
    {
      "from": 191.82,
      "to": 194.0,
      "sid": 89,
      "location": 2,
      "content": "房价和收入比是不是合理",
      "music": 0.0
    },
    {
      "from": 194.0,
      "to": 195.34,
      "sid": 90,
      "location": 2,
      "content": "能不能买得起",
      "music": 0.0
    },
    {
      "from": 195.34,
      "to": 197.23,
      "sid": 91,
      "location": 2,
      "content": "四供应情况",
      "music": 0.0
    },
    {
      "from": 197.23,
      "to": 198.93,
      "sid": 92,
      "location": 2,
      "content": "市场上的房子是多的",
      "music": 0.0
    },
    {
      "from": 198.93,
      "to": 199.51,
      "sid": 93,
      "location": 2,
      "content": "卖不完",
      "music": 0.0
    },
    {
      "from": 199.51,
      "to": 201.59,
      "sid": 94,
      "location": 2,
      "content": "还是已经去化的差不多了",
      "music": 0.0
    },
    {
      "from": 201.59,
      "to": 202.87,
      "sid": 95,
      "location": 2,
      "content": "用这四个维度",
      "music": 0.0
    },
    {
      "from": 202.87,
      "to": 206.01,
      "sid": 96,
      "location": 2,
      "content": "高盛把所有一二线城市打分排队",
      "music": 0.0
    },
    {
      "from": 206.01,
      "to": 209.75,
      "sid": 97,
      "location": 2,
      "content": "结果发现上海和深圳毫无疑问是第一梯队",
      "music": 0.0
    },
    {
      "from": 209.75,
      "to": 212.36,
      "sid": 98,
      "location": 2,
      "content": "他们在这四个维度上得分都很高",
      "music": 0.0
    },
    {
      "from": 212.36,
      "to": 214.32,
      "sid": 99,
      "location": 2,
      "content": "从去年底到今年一季度",
      "music": 0.0
    },
    {
      "from": 214.32,
      "to": 217.459,
      "sid": 100,
      "location": 2,
      "content": "这两个城市的房价已经出现了企稳迹象",
      "music": 0.0
    },
    {
      "from": 217.459,
      "to": 218.959,
      "sid": 101,
      "location": 2,
      "content": "那下一批是谁",
      "music": 0.0
    },
    {
      "from": 218.959,
      "to": 220.319,
      "sid": 102,
      "location": 2,
      "content": "报告精挑细选",
      "music": 0.0
    },
    {
      "from": 220.319,
      "to": 222.239,
      "sid": 103,
      "location": 2,
      "content": "选出了另外15个城市",
      "music": 0.0
    },
    {
      "from": 222.239,
      "to": 223.49,
      "sid": 104,
      "location": 2,
      "content": "包括哪些呢",
      "music": 0.0
    },
    {
      "from": 223.49,
      "to": 224.87,
      "sid": 105,
      "location": 2,
      "content": "首先是杭州",
      "music": 0.0
    },
    {
      "from": 224.87,
      "to": 230.87,
      "sid": 106,
      "location": 2,
      "content": "成都南京苏州武汉重庆广州这样的强二线城市",
      "music": 0.0
    },
    {
      "from": 230.87,
      "to": 233.45,
      "sid": 107,
      "location": 2,
      "content": "这些城市加上上海和深圳",
      "music": 0.0
    },
    {
      "from": 233.45,
      "to": 235.77,
      "sid": 108,
      "location": 2,
