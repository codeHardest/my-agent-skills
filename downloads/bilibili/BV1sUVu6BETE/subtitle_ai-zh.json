{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.32,
      "to": 1.5,
      "sid": 1,
      "location": 2,
      "content": "今天咱们来聊聊",
      "music": 0.0
    },
    {
      "from": 1.5,
      "to": 3.84,
      "sid": 2,
      "location": 2,
      "content": "高盛最近刚发布的一份",
      "music": 0.0
    },
    {
      "from": 3.84,
      "to": 7.36,
      "sid": 3,
      "location": 2,
      "content": "关于中国房地产市场的深度研究报告",
      "music": 0.0
    },
    {
      "from": 7.36,
      "to": 9.68,
      "sid": 4,
      "location": 2,
      "content": "这份报告的标题就很有意思啊",
      "music": 0.0
    },
    {
      "from": 9.68,
      "to": 14.42,
      "sid": 5,
      "location": 2,
      "content": "Positioning a hat no to share rally was pricing",
      "music": 0.0
    },
    {
      "from": 14.42,
      "to": 16.28,
      "sid": 6,
      "location": 2,
      "content": "就是说股价已经涨了",
      "music": 0.0
    },
    {
      "from": 16.28,
      "to": 18.08,
      "sid": 7,
      "location": 2,
      "content": "市场到底pricing了多少",
      "music": 0.0
    },
    {
      "from": 18.08,
      "to": 20.72,
      "sid": 8,
      "location": 2,
      "content": "预期对这个时间点特别关键",
      "music": 0.0
    },
    {
      "from": 20.72,
      "to": 23.46,
      "sid": 9,
      "location": 2,
      "content": "报告发布在2026年5月底",
      "music": 0.0
    },
    {
      "from": 23.46,
      "to": 28.54,
      "sid": 10,
      "location": 2,
      "content": "他们追踪的覆盖标企业从去年3月底到现在",
      "music": 0.0
    },
    {
      "from": 28.54,
      "to": 30.16,
      "sid": 11,
      "location": 2,
      "content": "平均涨了6%",
      "music": 0.0
    },
    {
      "from": 30.16,
      "to": 31.42,
      "sid": 12,
      "location": 2,
      "content": "其中更有意思的是",
      "music": 0.0
    },
    {
      "from": 31.42,
      "to": 33.24,
      "sid": 13,
      "location": 2,
      "content": "国有房企涨得更猛",
      "music": 0.0
    },
    {
      "from": 33.24,
      "to": 35.02,
      "sid": 14,
      "location": 2,
      "content": "平均涨了17%",
      "music": 0.0
    },
    {
      "from": 35.02,
      "to": 39.85,
      "sid": 15,
      "location": 2,
      "content": "向中海地产COLI和华润置地cr land这样的龙头",
      "music": 0.0
    },
    {
      "from": 39.85,
      "to": 43.25,
      "sid": 16,
      "location": 2,
      "content": "股价涨幅甚至达到了30%左右",
      "music": 0.0
    },
    {
      "from": 43.25,
      "to": 45.54,
      "sid": 17,
      "location": 2,
      "content": "哇30%",
      "music": 0.0
    },
    {
      "from": 45.54,
      "to": 48.08,
      "sid": 18,
      "location": 2,
      "content": "这个涨幅确实不小",
      "music": 0.0
    },
    {
      "from": 48.08,
      "to": 50.96,
      "sid": 19,
      "location": 2,
      "content": "我记得之前几轮房地产周期",
      "music": 0.0
    },
    {
      "from": 50.96,
      "to": 53.36,
      "sid": 20,
      "location": 2,
      "content": "股市好像都是领先指标",
      "music": 0.0
    },
    {
      "from": 53.36,
      "to": 55.66,
      "sid": 21,
      "location": 2,
      "content": "没错这个观察很准确",
      "music": 0.0
    },
    {
      "from": 55.66,
      "to": 57.9,
      "sid": 22,
      "location": 2,
      "content": "高盛在报告里特意提到了",
      "music": 0.0
    },
    {
      "from": 57.9,
      "to": 60.12,
      "sid": 23,
      "location": 2,
      "content": "从美国和日本的案例来看",
      "music": 0.0
    },
    {
      "from": 62.74,
      "to": 64.88,
      "sid": 24,
      "location": 2,
      "content": "比如美国房屋建筑商的股票",
      "music": 0.0
    },
    {
      "from": 64.88,
      "to": 68.5,
      "sid": 25,
      "location": 2,
      "content": "通常会比房价拐点提前一到两个季度触底",
      "music": 0.0
    },
    {
      "from": 68.5,
      "to": 70.26,
      "sid": 26,
      "location": 2,
      "content": "日本开发商的反应更早",
      "music": 0.0
    },
    {
      "from": 70.26,
      "to": 71.63,
      "sid": 27,
      "location": 2,
      "content": "能提前好几年",
      "music": 0.0
    },
    {
      "from": 71.63,
      "to": 72.95,
      "sid": 28,
      "location": 2,
      "content": "那现在的情况呢",
      "music": 0.0
    },
    {
      "from": 72.95,
      "to": 74.41,
      "sid": 29,
      "location": 2,
      "content": "市场是不是太乐观了",
      "music": 0.0
    },
    {
      "from": 74.41,
      "to": 77.85,
      "sid": 30,
      "location": 2,
      "content": "这就得看支撑股价上涨的逻辑是否扎实了",
      "music": 0.0
    },
    {
      "from": 77.85,
      "to": 78.91,
      "sid": 31,
      "location": 2,
      "content": "报告分析说",
      "music": 0.0
    },
    {
      "from": 78.91,
      "to": 82.57,
      "sid": 32,
      "location": 2,
      "content": "这次股价上涨主要是由两个因素驱动的",
      "music": 0.0
    },
    {
      "from": 82.57,
      "to": 85.85,
      "sid": 33,
      "location": 2,
      "content": "一个是净资产收益率roe的提升",
      "music": 0.0
    },
    {
      "from": 85.85,
      "to": 88.289,
      "sid": 34,
      "location": 2,
      "content": "另一个是股权成本的下降",
      "music": 0.0
    },
    {
      "from": 88.289,
      "to": 89.969,
      "sid": 35,
      "location": 2,
      "content": "这两个因素共同作用",
      "music": 0.0
    },
    {
      "from": 89.969,
      "to": 92.949,
      "sid": 36,
      "location": 2,
      "content": "才推动了股价从谷底大幅反弹",
      "music": 0.0
    },
    {
      "from": 92.949,
      "to": 94.249,
      "sid": 37,
      "location": 2,
      "content": "听起来挺有道理",
      "music": 0.0
    },
    {
      "from": 94.249,
      "to": 96.28,
      "sid": 38,
      "location": 2,
      "content": "但是我还是有点担心",
      "music": 0.0
    },
    {
      "from": 96.28,
      "to": 100.4,
      "sid": 39,
      "location": 2,
      "content": "毕竟房地产市场跟股市的关系挺复杂的",
      "music": 0.0
    },
    {
      "from": 100.4,
      "to": 102.09,
      "sid": 40,
      "location": 2,
      "content": "咱们能不能具体看看",
      "music": 0.0
    },
    {
      "from": 102.09,
      "to": 105.95,
      "sid": 41,
      "location": 2,
      "content": "这次上涨到底反映了什么样的市场预期",
      "music": 0.0
    },
    {
      "from": 106.53,
      "to": 109.3,
      "sid": 42,
      "location": 2,
      "content": "高盛做了一个很细致的分析",
      "music": 0.0
    },
    {
      "from": 109.3,
      "to": 112.56,
      "sid": 43,
      "location": 2,
      "content": "他们把中国城市分成了几个梯队",
      "music": 0.0
    },
    {
      "from": 112.56,
      "to": 117.46,
      "sid": 44,
      "location": 2,
      "content": "认为上海和深圳会是这轮复苏的领头羊",
      "music": 0.0
    },
    {
      "from": 117.46,
      "to": 120.03,
      "sid": 45,
      "location": 2,
      "content": "然后其他城市会陆续跟进",
      "music": 0.0
    },
    {
      "from": 120.03,
      "to": 122.99,
      "sid": 46,
      "location": 2,
      "content": "为了验证市场是不是反应过度",
      "music": 0.0
    },
    {
      "from": 122.99,
      "to": 127.47,
      "sid": 47,
      "location": 2,
      "content": "他们建立了一个所谓的四支柱复苏框架",
      "music": 0.0
    },
    {
      "from": 127.47,
      "to": 133.11,
      "sid": 48,
      "location": 2,
      "content": "四支柱是哪四个人口收入负担能力和供给",
      "music": 0.0
    },
    {
      "from": 133.11,
      "to": 134.99,
      "sid": 49,
      "location": 2,
      "content": "这是他们评估一个城市",
      "music": 0.0
    },
    {
      "from": 134.99,
      "to": 137.17,
      "sid": 50,
      "location": 2,
      "content": "房地产市场健康度的核心指标",
      "music": 0.0
    },
    {
      "from": 137.17,
      "to": 137.97,
      "sid": 51,
      "location": 2,
      "content": "具体来说",
      "music": 0.0
    },
    {
      "from": 137.97,
      "to": 141.4,
      "sid": 52,
      "location": 2,
      "content": "他们筛选出了15个第二梯队城市",
      "music": 0.0
    },
    {
      "from": 141.4,
      "to": 144.38,
      "sid": 53,
      "location": 2,
      "content": "这些城市加起来在全国的影响有多大呢",
      "music": 0.0
    },
    {
      "from": 144.38,
      "to": 146.38,
      "sid": 54,
      "location": 2,
      "content": "哦这个数字很重要啊",
      "music": 0.0
    },
    {
      "from": 146.38,
      "to": 147.95,
      "sid": 55,
      "location": 2,
      "content": "影响非常大",
      "music": 0.0
    },
    {
      "from": 147.95,
      "to": 151.209,
      "sid": 56,
      "location": 2,
      "content": "首先在2024年的数据基础上",
      "music": 0.0
    },
    {
      "from": 151.209,
      "to": 154.649,
      "sid": 57,
      "location": 2,
      "content": "这15个城市占了全国40%以上的",
      "music": 0.0
    },
    {
      "from": 154.649,
      "to": 157.4,
      "sid": 58,
      "location": 2,
      "content": "商品房销售额和固定资产投资",
      "music": 0.0
    },
    {
      "from": 157.4,
      "to": 161.48,
      "sid": 59,
      "location": 2,
      "content": "还有将近55%的总房产交易额",
      "music": 0.0
    },
    {
      "from": 161.48,
      "to": 162.78,
      "sid": 60,
      "location": 2,
      "content": "在经济层面",
      "music": 0.0
    },
    {
      "from": 162.78,
      "to": 166.24,
      "sid": 61,
      "location": 2,
      "content": "他们贡献了约30%的GDP和零售额",
      "music": 0.0
    },
    {
      "from": 166.24,
      "to": 168.78,
      "sid": 62,
      "location": 2,
      "content": "创造了近20%的就业岗位",
      "music": 0.0
    },
    {
      "from": 168.78,
      "to": 169.8,
      "sid": 63,
      "location": 2,
      "content": "更重要的是",
      "music": 0.0
    },
    {
      "from": 169.8,
      "to": 171.68,
      "sid": 64,
      "location": 2,
      "content": "这些城市的上市公司",
      "music": 0.0
    },
    {
      "from": 171.68,
      "to": 174.78,
      "sid": 65,
      "location": 2,
      "content": "总市值占全国的90%以上",
      "music": 0.0
    },
    {
      "from": 174.78,
      "to": 179.52,
      "sid": 66,
      "location": 2,
      "content": "家庭收入债务和储蓄的占比也接近30%",
      "music": 0.0
    },
    {
      "from": 179.52,
      "to": 181.18,
      "sid": 67,
      "location": 2,
      "content": "我的天这么算下来",
      "music": 0.0
    },
    {
      "from": 181.18,
      "to": 184.52,
      "sid": 68,
      "location": 2,
      "content": "这15个城市简直就是中国经济的半壁江山了",
      "music": 0.0
    },
    {
      "from": 184.52,
      "to": 185.68,
      "sid": 69,
      "location": 2,
      "content": "可以这么说",
      "music": 0.0
    },
    {
      "from": 185.68,
      "to": 188.44,
      "sid": 70,
      "location": 2,
      "content": "而且从房地产开发商的角度看",
      "music": 0.0
    },
    {
      "from": 188.44,
      "to": 190.49,
      "sid": 71,
      "location": 2,
      "content": "这些城市的价值更高",
      "music": 0.0
    },
    {
      "from": 190.49,
      "to": 194.61,
      "sid": 72,
      "location": 2,
      "content": "高盛估计他们覆盖的那些头部国企开发商",
      "music": 0.0
    },
    {
      "from": 194.61,
      "to": 198.57,
      "sid": 73,
      "location": 2,
      "content": "有差不多2/3的土地储备和可售资源",
      "music": 0.0
    },
    {
      "from": 198.57,
      "to": 200.45,
      "sid": 74,
      "location": 2,
      "content": "都集中在这些城市",
      "music": 0.0
    },
    {
      "from": 200.45,
      "to": 201.85,
      "sid": 75,
      "location": 2,
      "content": "2028年的时候",
      "music": 0.0
    },
    {
      "from": 201.85,
      "to": 205.93,
      "sid": 76,
      "location": 2,
      "content": "这些城市预计能贡献他们超过一半的利润",
      "music": 0.0
    },
    {
      "from": 205.93,
      "to": 206.94,
      "sid": 77,
      "location": 2,
      "content": "这就有意思了",
      "music": 0.0
    },
    {
      "from": 206.94,
      "to": 211.63,
      "sid": 78,
      "location": 2,
      "content": "如果这15个城市真的在2027年开始复苏",
      "music": 0.0
    },
    {
      "from": 211.63,
      "to": 214.29,
      "sid": 79,
      "location": 2,
      "content": "对开发商的业绩会有什么影响",
      "music": 0.0
    },
    {
      "from": 214.29,
      "to": 217.26,
      "sid": 80,
      "location": 2,
      "content": "这就涉及到他们对具体公司的分析了",
      "music": 0.0
    },
    {
      "from": 217.26,
      "to": 220.28,
      "sid": 81,
      "location": 2,
      "content": "他们以中海地产和华润置地为例",
      "music": 0.0
    },
    {
      "from": 220.28,
      "to": 224.03,
      "sid": 82,
      "location": 2,
      "content": "因为这两家公司在这一轮反弹中表现最好",
      "music": 0.0
    },
    {
      "from": 224.03,
      "to": 226.05,
      "sid": 83,
      "location": 2,
      "content": "中海地产上涨了30%",
      "music": 0.0
    },
    {
      "from": 226.05,
      "to": 228.19,
      "sid": 84,
      "location": 2,
      "content": "华润置地上涨了25%",
      "music": 0.0
    },
    {
      "from": 228.19,
      "to": 231.43,
      "sid": 85,
      "location": 2,
      "content": "嗯那他们的预期到底是怎么样的",
      "music": 0.0
    },
    {
      "from": 231.43,
      "to": 233.59,
      "sid": 86,
      "location": 2,
      "content": "报告用了两种情景来分析",
      "music": 0.0
    },
    {
      "from": 233.59,
      "to": 234.95,
      "sid": 87,
      "location": 2,
      "content": "一种是基准情景",
      "music": 0.0
    },
    {
      "from": 234.95,
      "to": 236.68,
      "sid": 88,
      "location": 2,
      "content": "一种是乐观情景",
      "music": 0.0
    },
    {
      "from": 236.68,
      "to": 238.22,
      "sid": 89,
      "location": 2,
      "content": "在乐观情景下",
      "music": 0.0
    },
    {
      "from": 238.22,
      "to": 241.28,
      "sid": 90,
      "location": 2,
      "content": "他们假设这15个城市的房价能上涨",
      "music": 0.0
    },
    {
      "from": 241.28,
      "to": 242.56,
      "sid": 91,
      "location": 2,
      "content": "15%",
      "music": 0.0
    },
    {
      "from": 242.56,
      "to": 245.75,
      "sid": 92,
      "location": 2,
      "content": "跟上海和深圳的预期涨幅差不多",
      "music": 0.0
    },
    {
      "from": 245.75,
      "to": 247.51,
      "sid": 93,
      "location": 2,
      "content": "15%的涨幅",
      "music": 0.0
    },
    {
      "from": 247.51,
      "to": 250.13,
      "sid": 94,
      "location": 2,
      "content": "这个假设算激进吗",
      "music": 0.0
    },
    {
      "from": 250.13,
      "to": 253.29,
      "sid": 95,
      "location": 2,
      "content": "在房地产行业里算比较乐观的了",
      "music": 0.0
    },
    {
      "from": 253.29,
      "to": 254.8,
      "sid": 96,
      "location": 2,
      "content": "但他们分析说",
      "music": 0.0
    },
    {
      "from": 254.8,
      "to": 256.74,
      "sid": 97,
      "location": 2,
      "content": "如果这个情景成立",
      "music": 0.0
    },
    {
      "from": 256.74,
      "to": 260.88,
      "sid": 98,
      "location": 2,
      "content": "中海地产和华润置地的盈利都会有大幅提升",
      "music": 0.0
    },
    {
      "from": 260.88,
      "to": 262.65,
      "sid": 99,
      "location": 2,
      "content": "特别是中海地产",
      "music": 0.0
    },
    {
      "from": 262.65,
      "to": 265.81,
      "sid": 100,
      "location": 2,
      "content": "因为他们80%以上的可售资源",
      "music": 0.0
    },
    {
      "from": 265.81,
      "to": 267.94,
      "sid": 101,
      "location": 2,
      "content": "都在这些领军城市",
      "music": 0.0
    },
    {
      "from": 267.94,
      "to": 269.28,
      "sid": 102,
      "location": 2,
      "content": "所以受益最大",
      "music": 0.0
    },
    {
      "from": 269.28,
      "to": 270.78,
      "sid": 103,
      "location": 2,
      "content": "那华润置地呢",
      "music": 0.0
    },
    {
      "from": 270.78,
      "to": 273.2,
      "sid": 104,
      "location": 2,
      "content": "华润置地的优势在于多元化",
      "music": 0.0
    },
    {
      "from": 273.2,
      "to": 275.02,
      "sid": 105,
      "location": 2,
      "content": "除了房地产开发",
      "music": 0.0
    },
    {
      "from": 275.02,
      "to": 276.82,
      "sid": 106,
      "location": 2,
      "content": "他们还有很多商业物业",
      "music": 0.0
    },
    {
