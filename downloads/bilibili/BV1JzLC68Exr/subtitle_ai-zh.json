    },
    {
      "from": 378.68,
      "to": 379.53,
      "sid": 165,
      "location": 2,
      "content": "展望未来",
      "music": 0.0
    },
    {
      "from": 379.53,
      "to": 380.29,
      "sid": 166,
      "location": 2,
      "content": "花旗认为",
      "music": 0.0
    },
    {
      "from": 380.29,
      "to": 383.21,
      "sid": 167,
      "location": 2,
      "content": "如果能源冲击最终对经济活动的损害",
      "music": 0.0
    },
    {
      "from": 383.21,
      "to": 385.27,
      "sid": 168,
      "location": 2,
      "content": "小于市场目前所担心的",
      "music": 0.0
    },
    {
      "from": 385.27,
      "to": 388.83,
      "sid": 169,
      "location": 2,
      "content": "那么最大的上行风险将会显现在这种情景下",
