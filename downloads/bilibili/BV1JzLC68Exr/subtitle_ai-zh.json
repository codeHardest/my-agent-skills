      "from": 371.02,
      "to": 372.2,
      "sid": 161,
      "location": 2,
      "content": "随着库存下降",
      "music": 0.0
    },
    {
      "from": 372.2,
      "to": 374.22,
      "sid": 162,
      "location": 2,
      "content": "市场不仅失去物理缓冲",
      "music": 0.0
    },
    {
      "from": 374.22,
      "to": 377.24,
      "sid": 163,
      "location": 2,
      "content": "还失去了与融资和套利结构相关的",
