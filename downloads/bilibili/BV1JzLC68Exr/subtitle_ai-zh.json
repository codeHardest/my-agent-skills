    },
    {
      "from": 388.83,
      "to": 392.44,
      "sid": 170,
      "location": 2,
      "content": "持续的供需赤字和持续的库存消耗",
      "music": 0.0
    },
    {
      "from": 392.44,
      "to": 394.0,
      "sid": 171,
      "location": 2,
      "content": "可能会逐步收紧",
