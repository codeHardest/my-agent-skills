{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 1.88,
      "sid": 1,
      "location": 2,
      "content": "华为这次来了个大的",
      "music": 0.0
    },
    {
      "from": 1.88,
      "to": 5.48,
      "sid": 2,
      "location": 2,
      "content": "5月25号上海s cs2026大会上",
      "music": 0.0
    },
    {
      "from": 5.48,
      "to": 8.6,
      "sid": 3,
      "location": 2,
      "content": "华为正式发布了一条新的半导体发展原则",
      "music": 0.0
    },
    {
      "from": 8.6,
      "to": 9.96,
      "sid": 4,
      "location": 2,
      "content": "叫做韬定律",
      "music": 0.0
    },
    {
      "from": 9.96,
      "to": 12.58,
      "sid": 5,
      "location": 2,
      "content": "制作出来之后基本是全网刷屏啊",
      "music": 0.0
    },
    {
      "from": 15.62,
      "to": 17.68,
      "sid": 6,
      "location": 2,
      "content": "社交媒体的讨论更是一片沸腾",
      "music": 0.0
    },
    {
      "from": 17.68,
      "to": 19.74,
      "sid": 7,
      "location": 2,
      "content": "有时候他能举终结摩尔定律的",
      "music": 0.0
    },
    {
      "from": 19.74,
      "to": 22.26,
      "sid": 8,
      "location": 2,
      "content": "有说他能重新定义芯片世界规矩",
      "music": 0.0
    },
    {
      "from": 22.26,
      "to": 24.1,
      "sid": 9,
      "location": 2,
      "content": "成为芯片武林盟主的",
      "music": 0.0
    },
    {
      "from": 24.1,
      "to": 26.72,
      "sid": 10,
      "location": 2,
      "content": "甚至有说华为能从此一转攻势",
      "music": 0.0
    },
    {
      "from": 26.72,
      "to": 29.02,
      "sid": 11,
      "location": 2,
      "content": "和高通苹果攻守异行的",
      "music": 0.0
    },
    {
      "from": 29.02,
      "to": 30.08,
      "sid": 12,
      "location": 2,
      "content": "光看这些报道",
      "music": 0.0
    },
    {
      "from": 30.08,
      "to": 31.7,
      "sid": 13,
      "location": 2,
      "content": "差友们大概也能感觉出来",
      "music": 0.0
    },
    {
      "from": 31.7,
      "to": 33.06,
      "sid": 14,
      "location": 2,
      "content": "这事听起来确实很大",
      "music": 0.0
    },
    {
      "from": 33.06,
      "to": 33.94,
      "sid": 15,
      "location": 2,
      "content": "又是新定律",
      "music": 0.0
    },
    {
      "from": 33.94,
      "to": 35.16,
      "sid": 16,
      "location": 2,
      "content": "又是新原则的",
      "music": 0.0
    },
    {
      "from": 35.16,
      "to": 36.72,
      "sid": 17,
      "location": 2,
      "content": "排面这块是拉满了",
      "music": 0.0
    },
    {
      "from": 36.72,
      "to": 39.72,
      "sid": 18,
      "location": 2,
      "content": "那么它真的和传说中一样颠覆半导体行业吗",
      "music": 0.0
    },
    {
      "from": 39.72,
      "to": 40.64,
      "sid": 19,
      "location": 2,
      "content": "更关键的是",
      "music": 0.0
    },
    {
      "from": 40.64,
      "to": 43.52,
      "sid": 20,
      "location": 2,
      "content": "它真能帮华为绕开先进制程的限制",
      "music": 0.0
    },
    {
      "from": 43.52,
      "to": 45.32,
      "sid": 21,
      "location": 2,
      "content": "追上甚至反超苹果",
      "music": 0.0
    },
    {
      "from": 45.32,
      "to": 46.34,
      "sid": 22,
      "location": 2,
      "content": "高通台积电吗",
      "music": 0.0
    },
    {
      "from": 46.34,
      "to": 46.68,
      "sid": 23,
      "location": 2,
      "content": "大家好",
      "music": 0.0
    },
    {
      "from": 46.68,
      "to": 47.4,
      "sid": 24,
      "location": 2,
      "content": "我是查明君",
      "music": 0.0
    },
    {
      "from": 47.4,
      "to": 49.32,
      "sid": 25,
      "location": 2,
      "content": "今天我们就来聊一聊华为搞出来的",
      "music": 0.0
    },
    {
      "from": 49.32,
      "to": 50.62,
      "sid": 26,
      "location": 2,
      "content": "它到底是什么",
      "music": 0.0
    },
    {
      "from": 50.62,
      "to": 52.96,
      "sid": 27,
      "location": 2,
      "content": "在工程里套一般指时间常数",
      "music": 0.0
    },
    {
      "from": 52.96,
      "to": 54.1,
      "sid": 28,
      "location": 2,
      "content": "具体到芯片里",
      "music": 0.0
    },
    {
      "from": 54.1,
      "to": 56.8,
      "sid": 29,
      "location": 2,
      "content": "可以简单理解成芯片里的时间成本",
      "music": 0.0
    },
    {
      "from": 56.8,
      "to": 59.78,
      "sid": 30,
      "location": 2,
      "content": "比如信号从一个地方传到另一个地方要多久",
      "music": 0.0
    },
    {
      "from": 59.78,
      "to": 62.26,
      "sid": 31,
      "location": 2,
      "content": "数据从一个单元流向另一个单元要多久",
      "music": 0.0
    },
    {
      "from": 62.26,
      "to": 64.83,
      "sid": 32,
      "location": 2,
      "content": "晶体管完成一次开关动作又要多久",
      "music": 0.0
    },
    {
      "from": 64.83,
      "to": 67.07,
      "sid": 33,
      "location": 2,
      "content": "但过去我们评价芯片是否进步",
      "music": 0.0
    },
    {
      "from": 67.07,
      "to": 69.13,
      "sid": 34,
      "location": 2,
      "content": "主要看的是它的空间属性",
      "music": 0.0
    },
    {
      "from": 69.13,
      "to": 71.78,
      "sid": 35,
      "location": 2,
      "content": "也就是熟悉的摩尔定律的底层逻辑",
      "music": 0.0
    },
    {
      "from": 71.78,
      "to": 73.04,
      "sid": 36,
      "location": 2,
      "content": "通过把晶体管做小",
      "music": 0.0
    },
    {
      "from": 73.04,
      "to": 75.91,
      "sid": 37,
      "location": 2,
      "content": "让芯片变得更密更快更省电",
      "music": 0.0
    },
    {
      "from": 75.91,
      "to": 77.79,
      "sid": 38,
      "location": 2,
      "content": "而华为这次提出了韬定律",
      "music": 0.0
    },
    {
      "from": 77.79,
      "to": 79.37,
      "sid": 39,
      "location": 2,
      "content": "则是换了一种观察角度",
      "music": 0.0
    },
    {
      "from": 79.37,
      "to": 82.2,
      "sid": 40,
      "location": 2,
      "content": "因为信息流动的时间替换晶体管的尺寸",
      "music": 0.0
    },
    {
      "from": 82.2,
      "to": 84.24,
      "sid": 41,
      "location": 2,
      "content": "作为芯片是否进步的衡量标准",
      "music": 0.0
    },
    {
      "from": 84.24,
      "to": 85.52,
      "sid": 42,
      "location": 2,
      "content": "用华为自己的说法",
      "music": 0.0
    },
    {
      "from": 85.52,
      "to": 88.52,
      "sid": 43,
      "location": 2,
      "content": "就是用时间微缩替代几何微缩",
      "music": 0.0
    },
    {
      "from": 88.52,
      "to": 89.5,
      "sid": 44,
      "location": 2,
      "content": "而强调的是",
      "music": 0.0
    },
    {
      "from": 89.5,
      "to": 90.92,
      "sid": 45,
      "location": 2,
      "content": "这并不是像牛顿定律",
      "music": 0.0
    },
    {
      "from": 90.92,
      "to": 93.12,
      "sid": 46,
      "location": 2,
      "content": "欧姆定律那样客观存在的自然规律",
      "music": 0.0
    },
    {
      "from": 93.12,
      "to": 95.76,
      "sid": 47,
      "location": 2,
      "content": "而是华为从工程实践中总结出来的",
      "music": 0.0
    },
    {
      "from": 95.76,
      "to": 97.83,
      "sid": 48,
      "location": 2,
      "content": "一套衡量芯片好不好的标准",
      "music": 0.0
    },
    {
      "from": 97.83,
      "to": 100.27,
      "sid": 49,
      "location": 2,
      "content": "可以简单理解成一个华为版的摩尔定律",
      "music": 0.0
    },
    {
      "from": 100.27,
      "to": 101.15,
      "sid": 50,
      "location": 2,
      "content": "不过说到这儿",
      "music": 0.0
    },
    {
      "from": 101.15,
      "to": 102.36,
      "sid": 51,
      "location": 2,
      "content": "可能有差友会问了",
      "music": 0.0
    },
    {
      "from": 102.36,
      "to": 105.08,
      "sid": 52,
      "location": 2,
      "content": "用纳米表示制成的说法已经用了这么多年",
      "music": 0.0
    },
    {
      "from": 105.08,
      "to": 106.36,
      "sid": 53,
      "location": 2,
      "content": "大家也都听习惯了",
      "music": 0.0
    },
    {
      "from": 106.36,
      "to": 107.44,
      "sid": 54,
      "location": 2,
      "content": "既然他一直能用",
      "music": 0.0
    },
    {
      "from": 107.44,
      "to": 110.76,
      "sid": 55,
      "location": 2,
      "content": "为什么现在华为还要给芯片换一把叫做涛的",
      "music": 0.0
    },
    {
      "from": 110.76,
      "to": 111.73,
      "sid": 56,
      "location": 2,
      "content": "新池子呢",
      "music": 0.0
    },
    {
      "from": 111.73,
      "to": 113.01,
      "sid": 57,
      "location": 2,
      "content": "要搞清楚这个问题",
      "music": 0.0
    },
    {
      "from": 113.01,
      "to": 115.01,
      "sid": 58,
      "location": 2,
      "content": "我们先要回到制程这个概念上",
      "music": 0.0
    },
    {
      "from": 115.01,
      "to": 115.81,
      "sid": 59,
      "location": 2,
      "content": "我们都知道",
      "music": 0.0
    },
    {
      "from": 115.81,
      "to": 116.71,
      "sid": 60,
      "location": 2,
      "content": "芯片的计算",
      "music": 0.0
    },
    {
      "from": 116.71,
      "to": 119.26,
      "sid": 61,
      "location": 2,
      "content": "本质上就是大量晶体管在不断的开关",
      "music": 0.0
    },
    {
      "from": 119.26,
      "to": 121.4,
      "sid": 62,
      "location": 2,
      "content": "一个晶体管可以理解成一个微型开关",
      "music": 0.0
    },
    {
      "from": 121.4,
      "to": 122.6,
      "sid": 63,
      "location": 2,
      "content": "它可以表示零和一",
      "music": 0.0
    },
    {
      "from": 122.6,
      "to": 125.35,
      "sid": 64,
      "location": 2,
      "content": "并且相互组合变成更复杂的逻辑电路",
      "music": 0.0
    },
    {
      "from": 125.35,
      "to": 127.21,
      "sid": 65,
      "location": 2,
      "content": "所以在其他条件接近的情况下",
      "music": 0.0
    },
    {
      "from": 127.21,
      "to": 128.4,
      "sid": 66,
      "location": 2,
      "content": "晶体管数量越多",
      "music": 0.0
    },
    {
      "from": 128.4,
      "to": 130.66,
      "sid": 67,
      "location": 2,
      "content": "芯片能同时处理的信息也就越多",
      "music": 0.0
    },
    {
      "from": 130.66,
      "to": 132.04,
      "sid": 68,
      "location": 2,
      "content": "计算能力也就越强",
      "music": 0.0
    },
    {
      "from": 132.04,
      "to": 135.04,
      "sid": 69,
      "location": 2,
      "content": "要在同样大小的芯片里塞进更多的晶体管",
      "music": 0.0
    },
    {
      "from": 135.04,
      "to": 137.54,
      "sid": 70,
      "location": 2,
      "content": "最直接的办法就是把晶体管做的更小",
      "music": 0.0
    },
    {
      "from": 137.54,
      "to": 140.12,
      "sid": 71,
      "location": 2,
      "content": "而最能直观表示晶体管大小的参数",
      "music": 0.0
    },
    {
      "from": 140.12,
      "to": 141.38,
      "sid": 72,
      "location": 2,
      "content": "则是山脊的长度",
      "music": 0.0
    },
    {
      "from": 141.38,
      "to": 143.35,
      "sid": 73,
      "location": 2,
      "content": "也就是原教旨主义的制程",
      "music": 0.0
    },
    {
      "from": 143.35,
      "to": 144.95,
      "sid": 74,
      "location": 2,
      "content": "珊迪像一块闸门一样",
      "music": 0.0
    },
    {
      "from": 144.95,
      "to": 146.45,
      "sid": 75,
      "location": 2,
      "content": "横在晶体管两极之间",
      "music": 0.0
    },
    {
      "from": 146.45,
      "to": 147.55,
      "sid": 76,
      "location": 2,
      "content": "负责控制电流",
      "music": 0.0
    },
    {
      "from": 147.55,
      "to": 149.09,
      "sid": 77,
      "location": 2,
      "content": "通断三级越短",
      "music": 0.0
    },
    {
      "from": 149.09,
      "to": 150.63,
      "sid": 78,
      "location": 2,
      "content": "闸门控制的通道就越短",
      "music": 0.0
    },
    {
      "from": 150.63,
      "to": 153.13,
      "sid": 79,
      "location": 2,
      "content": "同样的尺寸下能塞下更多晶体管",
      "music": 0.0
    },
    {
      "from": 153.13,
      "to": 155.85,
      "sid": 80,
      "location": 2,
      "content": "同时每次开关需要搬动的电荷更少",
      "music": 0.0
    },
    {
      "from": 155.85,
      "to": 157.11,
      "sid": 81,
      "location": 2,
      "content": "能耗也就越低",
      "music": 0.0
    },
    {
      "from": 157.11,
      "to": 159.07,
      "sid": 82,
      "location": 2,
      "content": "但今天我们常说的7NM",
      "music": 0.0
    },
    {
      "from": 159.07,
      "to": 159.47,
      "sid": 83,
      "location": 2,
      "content": "5nm",
      "music": 0.0
    },
    {
      "from": 159.47,
      "to": 161.79,
      "sid": 84,
      "location": 2,
      "content": "3NM其实已经不是一个长度单位",
      "music": 0.0
    },
    {
      "from": 161.79,
      "to": 163.65,
      "sid": 85,
      "location": 2,
      "content": "而是一个概括了晶体管密度",
      "music": 0.0
    },
    {
      "from": 163.65,
      "to": 165.68,
      "sid": 86,
      "location": 2,
      "content": "能耗和成本规律的综合指标",
      "music": 0.0
    },
    {
      "from": 165.68,
      "to": 166.9,
      "sid": 87,
      "location": 2,
      "content": "从1995年开始",
      "music": 0.0
    },
    {
      "from": 166.9,
      "to": 170.01,
      "sid": 88,
      "location": 2,
      "content": "山鸡长度和制程之间就不再有严格的对应关系",
      "music": 0.0
    },
    {
      "from": 170.01,
      "to": 172.29,
      "sid": 89,
      "location": 2,
      "content": "到14NMFINFIVE成为主流后",
      "music": 0.0
    },
    {
      "from": 172.29,
      "to": 175.7,
      "sid": 90,
      "location": 2,
      "content": "芯片铁带更是几乎和把山脊做短没什么关系了",
      "music": 0.0
    },
    {
      "from": 175.7,
      "to": 177.86,
      "sid": 91,
      "location": 2,
      "content": "我们说10NM比14NM先进",
      "music": 0.0
    },
    {
      "from": 177.86,
      "to": 180.1,
      "sid": 92,
      "location": 2,
      "content": "实际上说的是10NM芯片的性能",
      "music": 0.0
    },
    {
      "from": 180.1,
      "to": 183.0,
      "sid": 93,
      "location": 2,
      "content": "功耗成本和14NM比更有优势",
      "music": 0.0
    },
    {
      "from": 183.0,
      "to": 184.8,
      "sid": 94,
      "location": 2,
      "content": "所以只要这个数字变小之后",
      "music": 0.0
    },
    {
      "from": 184.8,
      "to": 186.64,
      "sid": 95,
      "location": 2,
      "content": "芯片仍然符合摩尔定律的规律",
      "music": 0.0
    },
    {
      "from": 186.64,
      "to": 189.14,
      "sid": 96,
      "location": 2,
      "content": "那么他就算不再有对应的真实物理量",
      "music": 0.0
    },
    {
      "from": 189.14,
      "to": 190.58,
      "sid": 97,
      "location": 2,
      "content": "也依然具有参考价值",
      "music": 0.0
    },
    {
      "from": 190.58,
      "to": 193.32,
      "sid": 98,
      "location": 2,
      "content": "于是志诚逐渐从山脊的物理长度",
      "music": 0.0
    },
    {
      "from": 193.32,
      "to": 194.65,
      "sid": 99,
      "location": 2,
      "content": "变成了一种厂牌",
      "music": 0.0
    },
    {
      "from": 194.65,
      "to": 197.09,
      "sid": 100,
      "location": 2,
      "content": "继续作为一种芯片性能指标的参考",
      "music": 0.0
    },
    {
      "from": 197.09,
      "to": 198.14,
      "sid": 101,
      "location": 2,
      "content": "被保留了下来",
      "music": 0.0
    },
    {
      "from": 198.14,
      "to": 201.02,
      "sid": 102,
      "location": 2,
      "content": "但甩开了物理规则这个锚定物后制成的概念",
      "music": 0.0
    },
    {
      "from": 201.02,
      "to": 202.56,
      "sid": 103,
      "location": 2,
      "content": "很快就被大家玩坏了",
      "music": 0.0
    },
    {
      "from": 202.56,
      "to": 203.92,
      "sid": 104,
      "location": 2,
      "content": "比如三星的3NM",
      "music": 0.0
    },
    {
      "from": 203.92,
      "to": 204.88,
      "sid": 105,
      "location": 2,
      "content": "台积电N3",
      "music": 0.0
    },
    {
      "from": 204.88,
      "to": 206.32,
      "sid": 106,
      "location": 2,
      "content": "英特尔的英特尔三",
      "music": 0.0
    },
    {
      "from": 206.32,
      "to": 208.36,
      "sid": 107,
      "location": 2,
      "content": "从名字上看好像都带个三",
      "music": 0.0
    },
    {
