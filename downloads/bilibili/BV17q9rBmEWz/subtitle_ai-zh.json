{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 3.38,
      "sid": 1,
      "location": 2,
      "content": "今天我们要讲的是最近中国的一线城市",
      "music": 0.0
    },
    {
      "from": 3.38,
      "to": 7.379,
      "sid": 2,
      "location": 2,
      "content": "二手房的销售数据出现了超预期的增长",
      "music": 0.0
    },
    {
      "from": 7.379,
      "to": 9.919,
      "sid": 3,
      "location": 2,
      "content": "但是呢我们对此是保持谨慎的啊",
      "music": 0.0
    },
    {
      "from": 9.919,
      "to": 12.739,
      "sid": 4,
      "location": 2,
      "content": "我们认为这个势头未必能够持续下去",
      "music": 0.0
    },
    {
      "from": 12.739,
      "to": 16.08,
      "sid": 5,
      "location": 2,
      "content": "而且我们也不觉得这种复苏会很快地",
      "music": 0.0
    },
    {
      "from": 16.08,
      "to": 17.92,
      "sid": 6,
      "location": 2,
      "content": "蔓延到更多的低线城市",
      "music": 0.0
    },
    {
      "from": 17.92,
      "to": 20.3,
      "sid": 7,
      "location": 2,
      "content": "没错这个话题最近确实挺火的",
      "music": 0.0
    },
    {
      "from": 20.3,
      "to": 21.26,
      "sid": 8,
      "location": 2,
      "content": "那我们就开始吧",
      "music": 0.0
    },
    {
      "from": 21.26,
      "to": 22.99,
      "sid": 9,
      "location": 2,
      "content": "首先我们要聚焦的就是",
      "music": 0.0
    },
    {
      "from": 22.99,
      "to": 25.27,
      "sid": 10,
      "location": 2,
      "content": "最近中国的这些一二线城市的",
      "music": 0.0
    },
    {
      "from": 25.27,
      "to": 28.11,
      "sid": 11,
      "location": 2,
      "content": "二手房的销售到底表现怎么样啊",
      "music": 0.0
    },
    {
      "from": 28.11,
      "to": 29.93,
      "sid": 12,
      "location": 2,
      "content": "有没有什么特别突出的数据",
      "music": 0.0
    },
    {
      "from": 29.93,
      "to": 31.03,
      "sid": 13,
      "location": 2,
      "content": "3月以来呢",
      "music": 0.0
    },
    {
      "from": 31.03,
      "to": 31.39,
      "sid": 14,
      "location": 2,
      "content": "呃",
      "music": 0.0
    },
    {
      "from": 31.39,
      "to": 33.29,
      "sid": 15,
      "location": 2,
      "content": "一线城市的二手房的销售",
      "music": 0.0
    },
    {
      "from": 33.29,
      "to": 35.03,
      "sid": 16,
      "location": 2,
      "content": "是超出了市场的预期的",
      "music": 0.0
    },
    {
      "from": 35.03,
      "to": 37.53,
      "sid": 17,
      "location": 2,
      "content": "并且热度呢持续的时间也比较长",
      "music": 0.0
    },
    {
      "from": 37.53,
      "to": 38.37,
      "sid": 18,
      "location": 2,
      "content": "比如上海",
      "music": 0.0
    },
    {
      "from": 38.37,
      "to": 38.85,
      "sid": 19,
      "location": 2,
      "content": "北京",
      "music": 0.0
    },
    {
      "from": 38.85,
      "to": 39.37,
      "sid": 20,
      "location": 2,
      "content": "南京",
      "music": 0.0
    },
    {
      "from": 39.37,
      "to": 40.13,
      "sid": 21,
      "location": 2,
      "content": "还有厦门啊",
      "music": 0.0
    },
    {
      "from": 40.13,
      "to": 41.01,
      "sid": 22,
      "location": 2,
      "content": "这几个城市",
      "music": 0.0
    },
    {
      "from": 41.01,
      "to": 43.57,
      "sid": 23,
      "location": 2,
      "content": "3月份的时候是同比增长了3%",
      "music": 0.0
    },
    {
      "from": 43.57,
      "to": 44.87,
      "sid": 24,
      "location": 2,
      "content": "到14%",
      "music": 0.0
    },
    {
      "from": 44.87,
      "to": 46.53,
      "sid": 25,
      "location": 2,
      "content": "到了4月份的话呢",
      "music": 0.0
    },
    {
      "from": 46.53,
      "to": 48.47,
      "sid": 26,
      "location": 2,
      "content": "这个数据就进一步的扩大到了",
      "music": 0.0
    },
    {
      "from": 48.47,
      "to": 51.15,
      "sid": 27,
      "location": 2,
      "content": "7%到25%",
      "music": 0.0
    },
    {
      "from": 51.15,
      "to": 53.57,
      "sid": 28,
      "location": 2,
      "content": "这个涨幅听起来确实挺厉害的",
      "music": 0.0
    },
    {
      "from": 53.57,
      "to": 55.32,
      "sid": 29,
      "location": 2,
      "content": "那是什么原因导致的呢",
      "music": 0.0
    },
    {
      "from": 55.32,
      "to": 57.38,
      "sid": 30,
      "location": 2,
      "content": "主要还是因为政策的支持啊",
      "music": 0.0
    },
    {
      "from": 57.38,
      "to": 60.76,
      "sid": 31,
      "location": 2,
      "content": "比如说上海和北京都放松了一些购房的政策",
      "music": 0.0
    },
    {
      "from": 60.76,
      "to": 63.62,
      "sid": 32,
      "location": 2,
      "content": "然后再加上一些老旧小区的租金",
      "music": 0.0
    },
    {
      "from": 63.62,
      "to": 65.0,
      "sid": 33,
      "location": 2,
      "content": "回报率提升了啊",
      "music": 0.0
    },
    {
      "from": 65.0,
      "to": 66.9,
      "sid": 34,
      "location": 2,
      "content": "还有就是去年年底的时候",
      "music": 0.0
    },
    {
      "from": 66.9,
      "to": 69.58,
      "sid": 35,
      "location": 2,
      "content": "积累了一些首次购房的需求啊",
      "music": 0.0
    },
    {
      "from": 69.58,
      "to": 71.12,
      "sid": 36,
      "location": 2,
      "content": "到了今年释放了出来",
      "music": 0.0
    },
    {
      "from": 71.12,
      "to": 74.2,
      "sid": 37,
      "location": 2,
      "content": "再加上大家的这个对市场的悲观情绪",
      "music": 0.0
    },
    {
      "from": 74.2,
      "to": 75.08,
      "sid": 38,
      "location": 2,
      "content": "也有所缓解",
      "music": 0.0
    },
    {
      "from": 75.08,
      "to": 77.57,
      "sid": 39,
      "location": 2,
      "content": "所以就造成了这样的一个情况诶",
      "music": 0.0
    },
    {
      "from": 77.57,
      "to": 80.33,
      "sid": 40,
      "location": 2,
      "content": "那这些强劲的二手房的销售",
      "music": 0.0
    },
    {
      "from": 80.33,
      "to": 82.53,
      "sid": 41,
      "location": 2,
      "content": "有没有带来什么连锁反应",
      "music": 0.0
    },
    {
      "from": 82.53,
      "to": 83.73,
      "sid": 42,
      "location": 2,
      "content": "比如说在房价上面",
      "music": 0.0
    },
    {
      "from": 83.73,
      "to": 85.41,
      "sid": 43,
      "location": 2,
      "content": "或者说在这个房源的供应上面",
      "music": 0.0
    },
    {
      "from": 85.41,
      "to": 86.73,
      "sid": 44,
      "location": 2,
      "content": "有的有的像上海",
      "music": 0.0
    },
    {
      "from": 86.73,
      "to": 87.59,
      "sid": 45,
      "location": 2,
      "content": "北京的话呢",
      "music": 0.0
    },
    {
      "from": 87.59,
      "to": 92.16,
      "sid": 46,
      "location": 2,
      "content": "就是二手房的价格出现了环比小幅的上涨啊",
      "music": 0.0
    },
    {
      "from": 92.16,
      "to": 93.76,
      "sid": 47,
      "location": 2,
      "content": "然后其他的一些二线城市",
      "music": 0.0
    },
    {
      "from": 93.76,
      "to": 95.48,
      "sid": 48,
      "location": 2,
      "content": "虽然说价格还是在下跌",
      "music": 0.0
    },
    {
      "from": 95.48,
      "to": 97.38,
      "sid": 49,
      "location": 2,
      "content": "但是跌幅已经收窄了",
      "music": 0.0
    },
    {
      "from": 97.38,
      "to": 99.42,
      "sid": 50,
      "location": 2,
      "content": "然后挂牌量也有一定的回落",
      "music": 0.0
    },
    {
      "from": 99.42,
      "to": 102.08,
      "sid": 51,
      "location": 2,
      "content": "下面咱们来聊一聊大家都很关心的问题啊",
      "music": 0.0
    },
    {
      "from": 102.08,
      "to": 106.129,
      "sid": 52,
      "location": 2,
      "content": "就是这种楼市的回暖究竟能不能够持续下去",
      "music": 0.0
    },
    {
      "from": 106.129,
      "to": 108.089,
      "sid": 53,
      "location": 2,
      "content": "以及大家现在对于后市",
      "music": 0.0
    },
    {
      "from": 108.089,
      "to": 109.609,
      "sid": 54,
      "location": 2,
      "content": "到底是一个什么样的心态",
      "music": 0.0
    },
    {
      "from": 109.609,
      "to": 111.649,
      "sid": 55,
      "location": 2,
      "content": "呃其实大部分的投资者",
      "music": 0.0
    },
    {
      "from": 111.649,
      "to": 113.06,
      "sid": 56,
      "location": 2,
      "content": "包括我们都是觉得",
      "music": 0.0
    },
    {
      "from": 113.06,
      "to": 116.9,
      "sid": 57,
      "location": 2,
      "content": "这一轮的销售的冲高是很难持续的啊",
      "music": 0.0
    },
    {
      "from": 116.9,
      "to": 119.25,
      "sid": 58,
      "location": 2,
      "content": "因为到了二季度本身就是一个淡季",
      "music": 0.0
    },
    {
      "from": 119.25,
      "to": 122.33,
      "sid": 59,
      "location": 2,
      "content": "再加上政策的刺激效果会慢慢的减退",
      "music": 0.0
    },
    {
      "from": 122.33,
      "to": 126.49,
      "sid": 60,
      "location": 2,
      "content": "然后居民的信心其实也还是比较脆弱的",
      "music": 0.0
    },
    {
      "from": 126.49,
      "to": 128.21,
      "sid": 61,
      "location": 2,
      "content": "所以我们觉得接下来的话",
      "music": 0.0
    },
    {
      "from": 128.21,
      "to": 130.61,
      "sid": 62,
      "location": 2,
      "content": "销售数据可能会再次的转弱",
      "music": 0.0
    },
    {
      "from": 130.61,
      "to": 132.63,
      "sid": 63,
      "location": 2,
      "content": "确实有很多不确定因素啊",
      "music": 0.0
    },
    {
      "from": 132.63,
      "to": 135.21,
      "sid": 64,
      "location": 2,
      "content": "那现在这种二手房的交易结构里面",
      "music": 0.0
    },
    {
      "from": 135.21,
      "to": 137.63,
      "sid": 65,
      "location": 2,
      "content": "是不是也透露出一些值得关注的信号",
      "music": 0.0
    },
    {
      "from": 138.63,
      "to": 141.75,
      "sid": 66,
      "location": 2,
      "content": "对呃低总价的房子占比是非常高的",
      "music": 0.0
    },
    {
      "from": 141.75,
      "to": 144.58,
      "sid": 67,
      "location": 2,
      "content": "像上海北京今年已经占到了八成以上",
      "music": 0.0
    },
    {
      "from": 144.58,
      "to": 146.7,
      "sid": 68,
      "location": 2,
      "content": "但是新房的市场还是很平淡",
      "music": 0.0
    },
    {
      "from": 146.7,
      "to": 148.38,
      "sid": 69,
      "location": 2,
      "content": "所以说二手房的这个增长",
      "music": 0.0
    },
    {
      "from": 148.38,
      "to": 151.289,
      "sid": 70,
      "location": 2,
      "content": "很大程度上是抢占了新房的份额",
      "music": 0.0
    },
    {
      "from": 151.289,
      "to": 154.369,
      "sid": 71,
      "location": 2,
      "content": "然后另外就是改善型的需求其实还是很弱的",
      "music": 0.0
    },
    {
      "from": 154.369,
      "to": 157.63,
      "sid": 72,
      "location": 2,
      "content": "那这个高端的房价其实调整还没有结束",
      "music": 0.0
    },
    {
      "from": 157.63,
      "to": 159.71,
      "sid": 73,
      "location": 2,
      "content": "那我们可能还需要再观察几个月",
      "music": 0.0
    },
    {
      "from": 159.71,
      "to": 162.05,
      "sid": 74,
      "location": 2,
      "content": "看看这个数据是不是真的能够持续",
      "music": 0.0
    },
    {
      "from": 162.05,
      "to": 165.459,
      "sid": 75,
      "location": 2,
      "content": "才能够判断说这是不是一个真正的反转好的",
      "music": 0.0
    },
    {
      "from": 165.459,
      "to": 168.439,
      "sid": 76,
      "location": 2,
      "content": "那为什么这次的这个房地产市场的回暖",
      "music": 0.0
    },
    {
      "from": 168.439,
      "to": 171.14,
      "sid": 77,
      "location": 2,
      "content": "没有能够带动更多的城市一起回升",
      "music": 0.0
    },
    {
      "from": 171.14,
      "to": 173.58,
      "sid": 78,
      "location": 2,
      "content": "就城市之间为什么会出现这么明显的分化",
      "music": 0.0
    },
    {
      "from": 173.58,
      "to": 176.64,
      "sid": 79,
      "location": 2,
      "content": "4月份虽然说整体的销售数据看起来不错",
      "music": 0.0
    },
    {
      "from": 176.64,
      "to": 179.36,
      "sid": 80,
      "location": 2,
      "content": "但是其实背后的原因很大程度上是因为",
      "music": 0.0
    },
    {
      "from": 179.36,
      "to": 181.459,
      "sid": 81,
      "location": 2,
      "content": "去年同期的基数比较低",
      "music": 0.0
    },
    {
      "from": 181.459,
      "to": 184.179,
      "sid": 82,
      "location": 2,
      "content": "其实大部分城市的表现都是平平的",
      "music": 0.0
    },
    {
      "from": 184.179,
      "to": 185.259,
      "sid": 83,
      "location": 2,
      "content": "甚至是下跌的",
      "music": 0.0
    },
    {
      "from": 185.259,
      "to": 187.459,
      "sid": 84,
      "location": 2,
      "content": "就是城市之间的差距是很大的",
      "music": 0.0
    },
    {
      "from": 187.459,
      "to": 189.7,
      "sid": 85,
      "location": 2,
      "content": "原来是基数效应在起作用啊",
      "music": 0.0
    },
    {
      "from": 189.7,
      "to": 192.9,
      "sid": 86,
      "location": 2,
      "content": "那是不是大家对于房子的投资属性的看法",
      "music": 0.0
    },
    {
      "from": 192.9,
      "to": 193.54,
      "sid": 87,
      "location": 2,
      "content": "也变了",
      "music": 0.0
    },
    {
      "from": 193.54,
      "to": 194.06,
      "sid": 88,
      "location": 2,
      "content": "没错",
      "music": 0.0
    },
    {
      "from": 194.06,
      "to": 196.95,
      "sid": 89,
      "location": 2,
      "content": "我们最新的这个ela wise的调查显示",
      "music": 0.0
    },
    {
      "from": 196.95,
      "to": 199.65,
      "sid": 90,
      "location": 2,
      "content": "经过了这么长时间的市场的低迷啊",
      "music": 0.0
    },
    {
      "from": 199.65,
      "to": 203.32,
      "sid": 91,
      "location": 2,
      "content": "现在大部分的居民已经不再认为房子是一个",
      "music": 0.0
    },
    {
      "from": 203.32,
      "to": 204.98,
      "sid": 92,
      "location": 2,
      "content": "稳赚不赔的投资了",
      "music": 0.0
    },
    {
      "from": 204.98,
      "to": 206.68,
      "sid": 93,
      "location": 2,
      "content": "他们也意识到了一个城市的房价",
      "music": 0.0
    },
    {
      "from": 206.68,
      "to": 210.67,
      "sid": 94,
      "location": 2,
      "content": "其实最终还是要靠人口和供需关系来决定的",
      "music": 0.0
    },
    {
      "from": 210.67,
      "to": 214.35,
      "sid": 95,
      "location": 2,
      "content": "所以这种普涨普跌的时代其实已经结束了",
      "music": 0.0
    },
    {
      "from": 214.35,
      "to": 217.17,
      "sid": 96,
      "location": 2,
      "content": "那在大部分的一二线城市企稳之前",
      "music": 0.0
    },
    {
      "from": 217.17,
      "to": 220.13,
      "sid": 97,
      "location": 2,
      "content": "整个市场的大环境还是很难真正的转好的",
      "music": 0.0
    },
    {
      "from": 220.13,
      "to": 221.03,
      "sid": 98,
      "location": 2,
      "content": "明白明白",
      "music": 0.0
    },
    {
      "from": 221.03,
      "to": 222.93,
      "sid": 99,
      "location": 2,
      "content": "那接下来我们要讨论的就是",
      "music": 0.0
    },
    {
      "from": 222.93,
      "to": 225.459,
      "sid": 100,
      "location": 2,
      "content": "投资建议和重点关注的指标了",
      "music": 0.0
    },
    {
      "from": 225.459,
      "to": 228.899,
      "sid": 101,
      "location": 2,
      "content": "就是说现在投资者应该紧盯哪些市场的变化",
      "music": 0.0
    },
    {
      "from": 228.899,
      "to": 231.239,
      "sid": 102,
      "location": 2,
      "content": "然后在投资策略上面有哪些建议呢",
      "music": 0.0
    },
    {
      "from": 231.239,
      "to": 233.36,
      "sid": 103,
      "location": 2,
      "content": "除了二手房的成交量之外",
      "music": 0.0
    },
    {
      "from": 233.36,
      "to": 235.28,
      "sid": 104,
      "location": 2,
      "content": "我们特别建议大家要关注",
      "music": 0.0
    },
    {
      "from": 235.28,
      "to": 239.519,
      "sid": 105,
      "location": 2,
      "content": "接下来这几个月就是567月份的新房的成交",
      "music": 0.0
    },
