{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.74,
      "to": 2.76,
      "sid": 1,
      "location": 2,
      "content": "欢迎大家回到老厉害的YOUTUBE频道",
      "music": 0.0
    },
    {
      "from": 2.76,
      "to": 5.8,
      "sid": 2,
      "location": 2,
      "content": "今天呢借着高盛和野村的两篇研报啊",
      "music": 0.0
    },
    {
      "from": 5.8,
      "to": 6.8,
      "sid": 3,
      "location": 2,
      "content": "和大家分享一下",
      "music": 0.0
    },
    {
      "from": 6.8,
      "to": 10.37,
      "sid": 4,
      "location": 2,
      "content": "新鲜出炉的4月中国官方的经济数据啊",
      "music": 0.0
    },
    {
      "from": 10.37,
      "to": 12.13,
      "sid": 5,
      "location": 2,
      "content": "那和前一期影片当中",
      "music": 0.0
    },
    {
      "from": 12.13,
      "to": 15.96,
      "sid": 6,
      "location": 2,
      "content": "对4月的金融数据的评价是非常相同的",
      "music": 0.0
    },
    {
      "from": 15.96,
      "to": 18.76,
      "sid": 7,
      "location": 2,
      "content": "出口和进口都是大幅双位数的增长",
      "music": 0.0
    },
    {
      "from": 18.76,
      "to": 20.7,
      "sid": 8,
      "location": 2,
      "content": "而且涨幅均超过了市场",
      "music": 0.0
    },
    {
      "from": 20.7,
      "to": 23.3,
      "sid": 9,
      "location": 2,
      "content": "与其这是应该看到的中国经济的亮点",
      "music": 0.0
    },
    {
      "from": 23.3,
      "to": 27.46,
      "sid": 10,
      "location": 2,
      "content": "也是能够体现中国在这次中东能源冲突之后啊",
      "music": 0.0
    },
    {
      "from": 27.46,
      "to": 30.87,
      "sid": 11,
      "location": 2,
      "content": "其实是为数不多的出口韧性比较强的国家",
      "music": 0.0
    },
    {
      "from": 30.87,
      "to": 32.69,
      "sid": 12,
      "location": 2,
      "content": "而且也是从去年开始",
      "music": 0.0
    },
    {
      "from": 32.69,
      "to": 35.03,
      "sid": 13,
      "location": 2,
      "content": "K型经济的上行的那一条腿啊",
      "music": 0.0
    },
    {
      "from": 35.03,
      "to": 37.75,
      "sid": 14,
      "location": 2,
      "content": "当然下行那一条腿主要指的是内旋",
      "music": 0.0
    },
    {
      "from": 37.75,
      "to": 40.29,
      "sid": 15,
      "location": 2,
      "content": "但是野村的研报中呢测算发现啊",
      "music": 0.0
    },
    {
      "from": 44.76,
      "to": 48.4,
      "sid": 16,
      "location": 2,
      "content": "如果剔除掉原油的输入性通胀和集成电路啊",
      "music": 0.0
    },
    {
      "from": 48.4,
      "to": 49.16,
      "sid": 17,
      "location": 2,
      "content": "这种啊",
      "music": 0.0
    },
    {
      "from": 49.16,
      "to": 50.76,
      "sid": 18,
      "location": 2,
      "content": "目前全球供不应求的这种商品",
      "music": 0.0
    },
    {
      "from": 50.76,
      "to": 52.46,
      "sid": 19,
      "location": 2,
      "content": "价格上涨的因素以外",
      "music": 0.0
    },
    {
      "from": 52.46,
      "to": 56.16,
      "sid": 20,
      "location": 2,
      "content": "出口的实际增速只有7%左右",
      "music": 0.0
    },
    {
      "from": 56.16,
      "to": 58.9,
      "sid": 21,
      "location": 2,
      "content": "那接下来呢我们就回到这两篇研报当中",
      "music": 0.0
    },
    {
      "from": 58.9,
      "to": 60.09,
      "sid": 22,
      "location": 2,
      "content": "野村的这篇研报啊",
      "music": 0.0
    },
    {
      "from": 60.09,
      "to": 62.65,
      "sid": 23,
      "location": 2,
      "content": "野村呢是基于4月的经济数据分析啊",
      "music": 0.0
    },
    {
      "from": 62.65,
      "to": 65.41,
      "sid": 24,
      "location": 2,
      "content": "认为中国当前的K型分化的经济呢",
      "music": 0.0
    },
    {
      "from": 65.41,
      "to": 68.36,
      "sid": 25,
      "location": 2,
      "content": "是阻碍了人民币升值的前景的",
      "music": 0.0
    },
    {
      "from": 68.36,
      "to": 71.78,
      "sid": 26,
      "location": 2,
      "content": "原因呢是尽管经常账户剩余啊持续扩张",
      "music": 0.0
    },
    {
      "from": 71.78,
      "to": 75.86,
      "sid": 27,
      "location": 2,
      "content": "意味着出口商结汇将带来大量的本币兑换需求",
      "music": 0.0
    },
    {
      "from": 75.86,
      "to": 77.62,
      "sid": 28,
      "location": 2,
      "content": "这其实也是之前我给大家分享的",
      "music": 0.0
    },
    {
      "from": 77.62,
      "to": 79.5,
      "sid": 29,
      "location": 2,
      "content": "高盛有一篇外汇研报",
      "music": 0.0
    },
    {
      "from": 79.5,
      "to": 81.43,
      "sid": 30,
      "location": 2,
      "content": "他们的一个核心的逻辑啊",
      "music": 0.0
    },
    {
      "from": 81.43,
      "to": 84.41,
      "sid": 31,
      "location": 2,
      "content": "但是呢国内需求疲软和看似通胀",
      "music": 0.0
    },
    {
      "from": 84.41,
      "to": 88.44,
      "sid": 32,
      "location": 2,
      "content": "实则通缩的状态不足以支撑人民币快速的走强",
      "music": 0.0
    },
    {
      "from": 88.44,
      "to": 89.92,
      "sid": 33,
      "location": 2,
      "content": "这块呢我也多说一句啊",
      "music": 0.0
    },
    {
      "from": 89.92,
      "to": 90.88,
      "sid": 34,
      "location": 2,
      "content": "野村的这个观点呢",
      "music": 0.0
    },
    {
      "from": 90.88,
      "to": 93.36,
      "sid": 35,
      "location": 2,
      "content": "和上周六在我的YOUTUBE频道里给大家分享的",
      "music": 0.0
    },
    {
      "from": 93.36,
      "to": 96.72,
      "sid": 36,
      "location": 2,
      "content": "大魔的那一篇下半年中国经济展望的研报",
      "music": 0.0
    },
    {
      "from": 96.72,
      "to": 98.08,
      "sid": 37,
      "location": 2,
      "content": "观点是非常类似的啊",
      "music": 0.0
    },
    {
      "from": 98.08,
      "to": 100.14,
      "sid": 38,
      "location": 2,
      "content": "当然呢这周一的宏观策略谈",
      "music": 0.0
    },
    {
      "from": 100.14,
      "to": 102.28,
      "sid": 39,
      "location": 2,
      "content": "他们又再次重重申了这个观点啊",
      "music": 0.0
    },
    {
      "from": 102.28,
      "to": 104.12,
      "sid": 40,
      "location": 2,
      "content": "就是国内目前的经济状况啊",
      "music": 0.0
    },
    {
      "from": 104.12,
      "to": 106.24,
      "sid": 41,
      "location": 2,
      "content": "是不支持人民币快速升值的",
      "music": 0.0
    },
    {
      "from": 106.24,
      "to": 108.66,
      "sid": 42,
      "location": 2,
      "content": "而之前我在频道里给大家分享过的那篇",
      "music": 0.0
    },
    {
      "from": 108.66,
      "to": 110.47,
      "sid": 43,
      "location": 2,
      "content": "高盛全球外汇团队",
      "music": 0.0
    },
    {
      "from": 110.47,
      "to": 113.29,
      "sid": 44,
      "location": 2,
      "content": "对人民币汇率的看法是不太一样的",
      "music": 0.0
    },
    {
      "from": 113.29,
      "to": 116.61,
      "sid": 45,
      "location": 2,
      "content": "因为高盛呢是绘制了一张比较长周期的图啊",
      "music": 0.0
    },
    {
      "from": 116.61,
      "to": 120.909,
      "sid": 46,
      "location": 2,
      "content": "发现我们的经常账户盈余占全球GDP的比重",
      "music": 0.0
    },
    {
      "from": 121.949,
      "to": 123.789,
      "sid": 47,
      "location": 2,
      "content": "是人民币汇率的一个先行指标",
      "music": 0.0
    },
    {
      "from": 123.789,
      "to": 125.389,
      "sid": 48,
      "location": 2,
      "content": "而从2025年开始",
      "music": 0.0
    },
    {
      "from": 125.389,
      "to": 128.429,
      "sid": 49,
      "location": 2,
      "content": "经常账户的盈余就在持续的扩张啊",
      "music": 0.0
    },
    {
      "from": 128.429,
      "to": 132.28,
      "sid": 50,
      "location": 2,
      "content": "特别是从它占全球GDP比例的这个视角来看啊",
      "music": 0.0
    },
    {
      "from": 132.28,
      "to": 134.22,
      "sid": 51,
      "location": 2,
      "content": "是在持续的提升的",
      "music": 0.0
    },
    {
      "from": 134.22,
      "to": 137.5,
      "sid": 52,
      "location": 2,
      "content": "那么也就意味着在2026年到2027年",
      "music": 0.0
    },
    {
      "from": 137.5,
      "to": 138.88,
      "sid": 53,
      "location": 2,
      "content": "按照历史推演的话",
      "music": 0.0
    },
    {
      "from": 138.88,
      "to": 140.78,
      "sid": 54,
      "location": 2,
      "content": "人民币是有升值的可能性的",
      "music": 0.0
    },
    {
      "from": 140.78,
      "to": 143.78,
      "sid": 55,
      "location": 2,
      "content": "但是呢大摩和野村似乎并不这么认为啊",
      "music": 0.0
    },
    {
      "from": 143.78,
      "to": 145.42,
      "sid": 56,
      "location": 2,
      "content": "从预测的点位上来看啊",
      "music": 0.0
    },
    {
      "from": 145.42,
      "to": 146.82,
      "sid": 57,
      "location": 2,
      "content": "高盛的全球外汇团队啊",
      "music": 0.0
    },
    {
      "from": 146.82,
      "to": 149.79,
      "sid": 58,
      "location": 2,
      "content": "是认为人民币在未来的12个月内啊",
      "music": 0.0
    },
    {
      "from": 149.79,
      "to": 151.97,
      "sid": 59,
      "location": 2,
      "content": "将升至美元兑人民币6.5",
      "music": 0.0
    },
    {
      "from": 151.97,
      "to": 152.97,
      "sid": 60,
      "location": 2,
      "content": "就是六块五",
      "music": 0.0
    },
    {
      "from": 152.97,
      "to": 155.97,
      "sid": 61,
      "location": 2,
      "content": "那作为对应的大摩给的大概是在六块七",
      "music": 0.0
    },
    {
      "from": 155.97,
      "to": 157.55,
      "sid": 62,
      "location": 2,
      "content": "毛5~6块八的这个区间啊",
      "music": 0.0
    },
    {
      "from": 157.55,
      "to": 159.09,
      "sid": 63,
      "location": 2,
      "content": "这里面差距还是比较大的",
      "music": 0.0
    },
    {
      "from": 159.09,
      "to": 161.25,
      "sid": 64,
      "location": 2,
      "content": "如果是六块七毛5~6块八这个区间的话",
      "music": 0.0
    },
    {
      "from": 161.25,
      "to": 164.21,
      "sid": 65,
      "location": 2,
      "content": "基本上意味着和目前人民币汇率之间",
      "music": 0.0
    },
    {
      "from": 164.21,
      "to": 165.71,
      "sid": 66,
      "location": 2,
      "content": "没有太大的差异啊",
      "music": 0.0
    },
    {
      "from": 165.71,
      "to": 168.87,
      "sid": 67,
      "location": 2,
      "content": "那回到野村这篇研报当中所说的K型经济啊",
      "music": 0.0
    },
    {
      "from": 168.87,
      "to": 172.6,
      "sid": 68,
      "location": 2,
      "content": "除了刚才提到的对于汇率啊可能没有支撑以外",
      "music": 0.0
    },
    {
      "from": 172.6,
      "to": 176.16,
      "sid": 69,
      "location": 2,
      "content": "那目前中国这样的出口强内虚弱的K型经济呢",
      "music": 0.0
    },
    {
      "from": 176.16,
      "to": 179.36,
      "sid": 70,
      "location": 2,
      "content": "也解释了为什么尽管股市在上行啊",
      "music": 0.0
    },
    {
      "from": 179.36,
      "to": 180.68,
      "sid": 71,
      "location": 2,
      "content": "特别是股市点位在上行",
      "music": 0.0
    },
    {
      "from": 180.68,
      "to": 183.22,
      "sid": 72,
      "location": 2,
      "content": "且我们现在处于一个AI爆发的时代啊",
      "music": 0.0
    },
    {
      "from": 183.22,
      "to": 185.1,
      "sid": 73,
      "location": 2,
      "content": "但是呢10年期国债收益率啊",
      "music": 0.0
    },
    {
      "from": 185.1,
      "to": 188.26,
      "sid": 74,
      "location": 2,
      "content": "从年初至今反而是下降了十个BP",
      "music": 0.0
    },
    {
      "from": 188.26,
      "to": 190.81,
      "sid": 75,
      "location": 2,
      "content": "特别是在没有降息的情况下",
      "music": 0.0
    },
    {
      "from": 190.81,
      "to": 193.83,
      "sid": 76,
      "location": 2,
      "content": "也就是说债券收益率曲线",
      "music": 0.0
    },
    {
      "from": 193.83,
      "to": 196.28,
      "sid": 77,
      "location": 2,
      "content": "短端没有什么变化的情况下",
      "music": 0.0
    },
    {
      "from": 196.28,
      "to": 197.48,
      "sid": 78,
      "location": 2,
      "content": "而长短啊",
      "music": 0.0
    },
    {
      "from": 197.48,
      "to": 201.38,
      "sid": 79,
      "location": 2,
      "content": "10年期的这一段从年初至今啊有下降趋势",
      "music": 0.0
    },
    {
      "from": 201.38,
      "to": 204.46,
      "sid": 80,
      "location": 2,
      "content": "收益率曲线呢也再次的趋向于平坦化",
      "music": 0.0
    },
    {
      "from": 204.46,
      "to": 205.82,
      "sid": 81,
      "location": 2,
      "content": "这其实呢也反映出啊",
      "music": 0.0
    },
    {
      "from": 205.82,
      "to": 207.54,
      "sid": 82,
      "location": 2,
      "content": "无论是企业还是居民",
      "music": 0.0
    },
    {
      "from": 207.54,
      "to": 211.34,
      "sid": 83,
      "location": 2,
      "content": "整个私营部门对未来经济预期仍然是偏弱的",
      "music": 0.0
    },
    {
      "from": 211.34,
      "to": 213.38,
      "sid": 84,
      "location": 2,
      "content": "那么风险偏好呢也更低啊",
      "music": 0.0
    },
    {
      "from": 213.38,
      "to": 215.54,
      "sid": 85,
      "location": 2,
      "content": "特别是大家看到了股市的上行以后",
      "music": 0.0
    },
    {
      "from": 215.54,
      "to": 216.98,
      "sid": 86,
      "location": 2,
      "content": "还愿意去买债对吧",
      "music": 0.0
    },
    {
      "from": 216.98,
      "to": 221.44,
      "sid": 87,
      "location": 2,
      "content": "那自然呢这样的一种经济预期和风险偏好啊",
      "music": 0.0
    },
    {
      "from": 221.44,
      "to": 224.5,
      "sid": 88,
      "location": 2,
      "content": "也就意味着内需和消费还是比较弱",
      "music": 0.0
    },
    {
      "from": 224.5,
      "to": 225.92,
      "sid": 89,
      "location": 2,
      "content": "因此呢野村认为啊",
      "music": 0.0
    },
    {
      "from": 225.92,
      "to": 228.76,
      "sid": 90,
      "location": 2,
      "content": "中国的政策制定者还是不能懈怠的",
      "music": 0.0
    },
    {
      "from": 228.76,
      "to": 230.92,
      "sid": 91,
      "location": 2,
      "content": "他的原话呢叫做北京",
      "music": 0.0
    },
    {
      "from": 230.92,
      "to": 232.88,
      "sid": 92,
      "location": 2,
      "content": "Has no room for complacency",
      "music": 0.0
    },
    {
      "from": 232.88,
      "to": 235.8,
      "sid": 93,
      "location": 2,
      "content": "野村呢是建议我们需要尽快出台政策",
      "music": 0.0
    },
    {
      "from": 235.8,
      "to": 237.28,
      "sid": 94,
      "location": 2,
      "content": "来稳定经济增长",
      "music": 0.0
    },
    {
      "from": 237.28,
      "to": 239.94,
      "sid": 95,
      "location": 2,
      "content": "那对于第二季度的GDP增速判断啊",
      "music": 0.0
    },
    {
      "from": 239.94,
      "to": 241.66,
      "sid": 96,
      "location": 2,
      "content": "野村仍然是提到说",
      "music": 0.0
    },
    {
      "from": 241.66,
      "to": 244.86,
      "sid": 97,
      "location": 2,
      "content": "他们维持着他们大幅低于市场共识的",
      "music": 0.0
    },
    {
      "from": 244.86,
      "to": 246.06,
      "sid": 98,
      "location": 2,
      "content": "一个预期判断",
      "music": 0.0
    },
    {
      "from": 246.06,
      "to": 249.36,
      "sid": 99,
      "location": 2,
      "content": "认为二季度中国的实际GDP增速",
      "music": 0.0
    },
    {
      "from": 249.36,
      "to": 251.72,
      "sid": 100,
      "location": 2,
      "content": "仅仅只有4.1%啊",
      "music": 0.0
    },
    {
      "from": 251.72,
      "to": 253.44,
      "sid": 101,
      "location": 2,
      "content": "可以看到在我鼠标的这个位置",
      "music": 0.0
    },
    {
      "from": 253.44,
      "to": 255.14,
      "sid": 102,
      "location": 2,
      "content": "而市场共识是多少呢",
      "music": 0.0
    },
    {
      "from": 255.14,
      "to": 257.0,
      "sid": 103,
