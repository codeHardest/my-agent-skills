    },
    {
      "from": 59.79,
      "to": 62.95,
      "sid": 30,
      "location": 2,
      "content": "但结构性机会正在浮现啊",
      "music": 0.0
    },
    {
      "from": 62.95,
      "to": 64.77,
      "sid": 31,
      "location": 2,
      "content": "这意思是大锅饭没了",
      "music": 0.0
    },
    {
      "from": 64.77,
      "to": 66.31,
      "sid": 32,
      "location": 2,
      "content": "得开小灶没错",
      "music": 0.0
    },
    {
      "from": 66.31,
      "to": 67.83,
      "sid": 33,
      "location": 2,
      "content": "尤其值得注意的是",
      "music": 0.0
    },
    {
      "from": 67.83,
      "to": 71.449,
      "sid": 34,
      "location": 2,
