    },
    {
      "from": 54.99,
      "to": 56.43,
      "sid": 28,
      "location": 2,
      "content": "核心结论很明确",
      "music": 0.0
    },
    {
      "from": 56.43,
      "to": 59.79,
      "sid": 29,
      "location": 2,
      "content": "行业还没走出底部系统性反弹南线",
