    },
    {
      "from": 20.53,
      "to": 21.45,
      "sid": 13,
      "location": 2,
      "content": "但注意啊",
      "music": 0.0
    },
    {
      "from": 21.45,
      "to": 22.69,
      "sid": 14,
      "location": 2,
      "content": "这个2.1%",
      "music": 0.0
    },
    {
      "from": 22.69,
      "to": 25.97,
      "sid": 15,
      "location": 2,
      "content": "是全国商品房销售单价的同比涨幅",
      "music": 0.0
    },
    {
      "from": 25.97,
      "to": 28.06,
      "sid": 16,
      "location": 2,
      "content": "并非70城房价指数",
      "music": 0.0
    },
    {
      "from": 28.06,
      "to": 30.18,
      "sid": 17,
      "location": 2,
      "content": "后者4月环比仍是下跌的",
      "music": 0.0
    },
    {
      "from": 30.18,
      "to": 32.769,
      "sid": 18,
      "location": 2,
      "content": "合着是被平均啦对喽",
      "music": 0.0
    },
    {
      "from": 32.769,
      "to": 35.369,
      "sid": 19,
      "location": 2,
      "content": "二手房挂牌量高起",
