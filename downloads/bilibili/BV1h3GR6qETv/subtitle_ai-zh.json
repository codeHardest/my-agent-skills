    },
    {
      "from": 35.369,
      "to": 37.269,
      "sid": 20,
      "location": 2,
      "content": "租金连续下行",
      "music": 0.0
    },
    {
      "from": 37.269,
      "to": 40.739,
      "sid": 21,
      "location": 2,
      "content": "所谓的企稳可能只是局部幻觉",
      "music": 0.0
    },
    {
      "from": 40.739,
      "to": 42.399,
      "sid": 22,
      "location": 2,
      "content": "今天咱们就来拆解",
      "music": 0.0
    },
    {
      "from": 42.399,
      "to": 45.019,
      "sid": 23,
      "location": 2,
      "content": "招商证券对2026年1月到4月",
