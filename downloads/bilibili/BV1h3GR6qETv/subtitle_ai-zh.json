    },
    {
      "from": 71.449,
      "to": 74.829,
      "sid": 35,
      "location": 2,
      "content": "转向挑好公司单打独斗的alpha时代",
      "music": 0.0
    },
    {
      "from": 74.829,
      "to": 76.45,
      "sid": 36,
      "location": 2,
      "content": "这得挑花眼了吧",
      "music": 0.0
    },
    {
      "from": 76.45,
      "to": 77.87,
      "sid": 37,
      "location": 2,
      "content": "先看销售端",
      "music": 0.0
    },
    {
      "from": 77.87,
      "to": 80.95,
      "sid": 38,
      "location": 2,
      "content": "4月销售面积同比跌了9.5%",
