{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.02,
      "to": 0.54,
      "sid": 1,
      "location": 2,
      "content": "各位好",
      "music": 0.0
    },
    {
      "from": 0.54,
      "to": 2.78,
      "sid": 2,
      "location": 2,
      "content": "欢迎收看cs同学四月的宏观推演",
      "music": 0.0
    },
    {
      "from": 2.78,
      "to": 5.64,
      "sid": 3,
      "location": 2,
      "content": "本月今年开年后影响力最大的宏观事件",
      "music": 0.0
    },
    {
      "from": 5.64,
      "to": 6.44,
      "sid": 4,
      "location": 2,
      "content": "梅以伊战争",
      "music": 0.0
    },
    {
      "from": 6.44,
      "to": 9.02,
      "sid": 5,
      "location": 2,
      "content": "如我们上个月的推演出现了明显的降级",
      "music": 0.0
    },
    {
      "from": 9.02,
      "to": 12.0,
      "sid": 6,
      "location": 2,
      "content": "虽然后续美伊两方一直还有各种反复出现",
      "music": 0.0
    },
    {
      "from": 12.0,
      "to": 13.98,
      "sid": 7,
      "location": 2,
      "content": "但战争升级的可能性已经很小",
      "music": 0.0
    },
    {
      "from": 13.98,
      "to": 17.2,
      "sid": 8,
      "location": 2,
      "content": "目前拉锯主要还是为了拿到更多谈判的利益",
      "music": 0.0
    },
    {
      "from": 17.2,
      "to": 19.32,
      "sid": 9,
      "location": 2,
      "content": "而全球资本市场呢也在停战之后",
      "music": 0.0
    },
    {
      "from": 19.32,
      "to": 20.5,
      "sid": 10,
      "location": 2,
      "content": "出现了大幅的反弹",
      "music": 0.0
    },
    {
      "from": 20.5,
      "to": 22.72,
      "sid": 11,
      "location": 2,
      "content": "而且已经对后续的各种反复脱敏",
      "music": 0.0
    },
    {
      "from": 22.72,
      "to": 24.98,
      "sid": 12,
      "location": 2,
      "content": "除非战争再次超预期的升级",
      "music": 0.0
    },
    {
      "from": 24.98,
      "to": 28.36,
      "sid": 13,
      "location": 2,
      "content": "否则这次战争在未来对市场的影响将会复制",
      "music": 0.0
    },
    {
      "from": 28.36,
      "to": 30.48,
      "sid": 14,
      "location": 2,
      "content": "当年的俄乌战争以及去年的关税战",
      "music": 0.0
    },
    {
      "from": 30.48,
      "to": 32.08,
      "sid": 15,
      "location": 2,
      "content": "变得越来越不受关注",
      "music": 0.0
    },
    {
      "from": 32.08,
      "to": 35.28,
      "sid": 16,
      "location": 2,
      "content": "而我国凭借多年沉淀下来的能源进口多元化",
      "music": 0.0
    },
    {
      "from": 35.28,
      "to": 36.44,
      "sid": 17,
      "location": 2,
      "content": "在这场危机里呢",
      "music": 0.0
    },
    {
      "from": 36.44,
      "to": 38.2,
      "sid": 18,
      "location": 2,
      "content": "成为了亚洲各制造业出口",
      "music": 0.0
    },
    {
      "from": 38.2,
      "to": 40.269,
      "sid": 19,
      "location": 2,
      "content": "国力影响最小的几个国家之一",
      "music": 0.0
    },
    {
      "from": 40.269,
      "to": 42.989,
      "sid": 20,
      "location": 2,
      "content": "虽然上游价格也跟随国际油价的上涨",
      "music": 0.0
    },
    {
      "from": 42.989,
      "to": 44.269,
      "sid": 21,
      "location": 2,
      "content": "而出现了部分的上涨",
      "music": 0.0
    },
    {
      "from": 44.269,
      "to": 46.31,
      "sid": 22,
      "location": 2,
      "content": "但总体供应并未出现失衡",
      "music": 0.0
    },
    {
      "from": 46.31,
      "to": 47.31,
      "sid": 23,
      "location": 2,
      "content": "中游制造业呢",
      "music": 0.0
    },
    {
      "from": 47.31,
      "to": 49.89,
      "sid": 24,
      "location": 2,
      "content": "反而在近期出现了一定程度的逆势扩张",
      "music": 0.0
    },
    {
      "from": 49.89,
      "to": 52.05,
      "sid": 25,
      "location": 2,
      "content": "而且出口呢也继续保持增长的势头",
      "music": 0.0
    },
    {
      "from": 52.05,
      "to": 55.08,
      "sid": 26,
      "location": 2,
      "content": "如果这次危机一直延导致国际油价高居不下",
      "music": 0.0
    },
    {
      "from": 55.08,
      "to": 56.84,
      "sid": 27,
      "location": 2,
      "content": "那我国凭借着成本优势",
      "music": 0.0
    },
    {
      "from": 56.84,
      "to": 57.88,
      "sid": 28,
      "location": 2,
      "content": "反而有概率复刻",
      "music": 0.0
    },
    {
      "from": 57.88,
      "to": 60.24,
      "sid": 29,
      "location": 2,
      "content": "当年疫情导致的国外制造业停摆",
      "music": 0.0
    },
    {
      "from": 60.24,
      "to": 61.959,
      "sid": 30,
      "location": 2,
      "content": "国内订单暴涨的剧情",
      "music": 0.0
    },
    {
      "from": 61.959,
      "to": 63.439,
      "sid": 31,
      "location": 2,
      "content": "但同样值得关注的是",
      "music": 0.0
    },
    {
      "from": 63.439,
      "to": 65.459,
      "sid": 32,
      "location": 2,
      "content": "我们前几期推演的地方政府投资",
      "music": 0.0
    },
    {
      "from": 65.459,
      "to": 67.399,
      "sid": 33,
      "location": 2,
      "content": "在二季度出现明显降温的预测",
      "music": 0.0
    },
    {
      "from": 67.399,
      "to": 69.039,
      "sid": 34,
      "location": 2,
      "content": "越来越有实现的可能了",
      "music": 0.0
    },
    {
      "from": 69.039,
      "to": 72.58,
      "sid": 35,
      "location": 2,
      "content": "未来一段时间通胀以及价格的回升是否能持续",
      "music": 0.0
    },
    {
      "from": 72.58,
      "to": 74.56,
      "sid": 36,
      "location": 2,
      "content": "以及工业端由上而下的复苏",
      "music": 0.0
    },
    {
      "from": 74.56,
      "to": 77.12,
      "sid": 37,
      "location": 2,
      "content": "能否成为政府端发债减速度的替代",
      "music": 0.0
    },
    {
      "from": 77.12,
      "to": 80.72,
      "sid": 38,
      "location": 2,
      "content": "将成为决定我国宏观经济走向的两个关键变量",
      "music": 0.0
    },
    {
      "from": 80.72,
      "to": 81.78,
      "sid": 39,
      "location": 2,
      "content": "而美国方面呢",
      "music": 0.0
    },
    {
      "from": 81.78,
      "to": 84.1,
      "sid": 40,
      "location": 2,
      "content": "高油价目前对美国经济造成的影响",
      "music": 0.0
    },
    {
      "from": 84.1,
      "to": 85.56,
      "sid": 41,
      "location": 2,
      "content": "跟美联储的判断一致",
      "music": 0.0
    },
    {
      "from": 85.56,
      "to": 87.72,
      "sid": 42,
      "location": 2,
      "content": "短时间内并未造成实际的伤害",
      "music": 0.0
    },
    {
      "from": 87.72,
      "to": 89.32,
      "sid": 43,
      "location": 2,
      "content": "目前更多的显性影响",
      "music": 0.0
    },
    {
      "from": 89.32,
      "to": 91.94,
      "sid": 44,
      "location": 2,
      "content": "主要是对居民的消费信心和社会的稳定性",
      "music": 0.0
    },
    {
      "from": 94.82,
      "to": 97.04,
      "sid": 45,
      "location": 2,
      "content": "而且未来在5月有访问我国",
      "music": 0.0
    },
    {
      "from": 97.04,
      "to": 98.0,
      "sid": 46,
      "location": 2,
      "content": "6月有世界杯",
      "music": 0.0
    },
    {
      "from": 98.0,
      "to": 100.98,
      "sid": 47,
      "location": 2,
      "content": "7月有美国建国典礼等重大的时间节点",
      "music": 0.0
    },
    {
      "from": 100.98,
      "to": 102.18,
      "sid": 48,
      "location": 2,
      "content": "所以4月底到5月",
      "music": 0.0
    },
    {
      "from": 102.18,
      "to": 104.64,
      "sid": 49,
      "location": 2,
      "content": "中美伊冲突呢必须要有个了结了",
      "music": 0.0
    },
    {
      "from": 104.64,
      "to": 106.06,
      "sid": 50,
      "location": 2,
      "content": "具体呢还是要看核问题",
      "music": 0.0
    },
    {
      "from": 106.06,
      "to": 108.16,
      "sid": 51,
      "location": 2,
      "content": "伊朗方面能否出现让步好了",
      "music": 0.0
    },
    {
      "from": 108.16,
      "to": 109.24,
      "sid": 52,
      "location": 2,
      "content": "大的方向我们聊完",
      "music": 0.0
    },
    {
      "from": 109.24,
      "to": 111.8,
      "sid": 53,
      "location": 2,
      "content": "接下来我们进入宏观数据的细化分析板块",
      "music": 0.0
    },
    {
      "from": 111.8,
      "to": 114.24,
      "sid": 54,
      "location": 2,
      "content": "近期国内经济最大的看点就是通胀",
      "music": 0.0
    },
    {
      "from": 114.24,
      "to": 116.82,
      "sid": 55,
      "location": 2,
      "content": "在连续3年第五排位后的除夕抬头",
      "music": 0.0
    },
    {
      "from": 116.82,
      "to": 117.46,
      "sid": 56,
      "location": 2,
      "content": "居民物价",
      "music": 0.0
    },
    {
      "from": 117.46,
      "to": 120.38,
      "sid": 57,
      "location": 2,
      "content": "CPI呢已经连续两个月占在了1%以上",
      "music": 0.0
    },
    {
      "from": 120.38,
      "to": 122.18,
      "sid": 58,
      "location": 2,
      "content": "这是疫情放开后的首次",
      "music": 0.0
    },
    {
      "from": 122.18,
      "to": 125.56,
      "sid": 59,
      "location": 2,
      "content": "而工业物价PPI呢更是时隔了4年再次同比回正",
      "music": 0.0
    },
    {
      "from": 125.56,
      "to": 128.16,
      "sid": 60,
      "location": 2,
      "content": "并且也已经连续六个月保持环比上涨",
      "music": 0.0
    },
    {
      "from": 128.16,
      "to": 130.16,
      "sid": 61,
      "location": 2,
      "content": "这也是我做宏观推演这个系列以来",
      "music": 0.0
    },
    {
      "from": 130.16,
      "to": 132.37,
      "sid": 62,
      "location": 2,
      "content": "PPI首次的正增长着实不易",
      "music": 0.0
    },
    {
      "from": 132.37,
      "to": 134.45,
      "sid": 63,
      "location": 2,
      "content": "但就像咱们上期推演的这个月",
      "music": 0.0
    },
    {
      "from": 134.45,
      "to": 135.69,
      "sid": 64,
      "location": 2,
      "content": "全国物价的抬升呢",
      "music": 0.0
    },
    {
      "from": 135.69,
      "to": 136.99,
      "sid": 65,
      "location": 2,
      "content": "其实早在预期之内",
      "music": 0.0
    },
    {
      "from": 136.99,
      "to": 140.16,
      "sid": 66,
      "location": 2,
      "content": "尤其是工业品价格方面出现了明显边际改善",
      "music": 0.0
    },
    {
      "from": 140.16,
      "to": 142.28,
      "sid": 67,
      "location": 2,
      "content": "那主要原因呢还是来自于美伊冲突",
      "music": 0.0
    },
    {
      "from": 142.28,
      "to": 144.36,
      "sid": 68,
      "location": 2,
      "content": "油价升高导致的输入型通胀",
      "music": 0.0
    },
    {
      "from": 144.36,
      "to": 145.88,
      "sid": 69,
      "location": 2,
      "content": "原油呢是现代工业之母",
      "music": 0.0
    },
    {
      "from": 145.88,
      "to": 146.64,
      "sid": 70,
      "location": 2,
      "content": "油价的升高",
      "music": 0.0
    },
    {
      "from": 146.64,
      "to": 149.5,
      "sid": 71,
      "location": 2,
      "content": "直接影响到了绝大多数中上游工业品的成本",
      "music": 0.0
    },
    {
      "from": 149.5,
      "to": 150.94,
      "sid": 72,
      "location": 2,
      "content": "叠加上因为去年返利卷",
      "music": 0.0
    },
    {
      "from": 150.94,
      "to": 153.1,
      "sid": 73,
      "location": 2,
      "content": "拉动了一系列供需失衡的工业品",
      "music": 0.0
    },
    {
      "from": 153.1,
      "to": 154.4,
      "sid": 74,
      "location": 2,
      "content": "价格脱离了底部",
      "music": 0.0
    },
    {
      "from": 154.4,
      "to": 155.48,
      "sid": 75,
      "location": 2,
      "content": "美国的制造业回流",
      "music": 0.0
    },
    {
      "from": 155.48,
      "to": 157.16,
      "sid": 76,
      "location": 2,
      "content": "又导致了有色金属的牛市",
      "music": 0.0
    },
    {
      "from": 157.16,
      "to": 159.06,
      "sid": 77,
      "location": 2,
      "content": "以及AI投资呢拉动了电子",
      "music": 0.0
    },
    {
      "from": 159.06,
      "to": 161.2,
      "sid": 78,
      "location": 2,
      "content": "电气相关行业景气度则持续抬升",
      "music": 0.0
    },
    {
      "from": 161.2,
      "to": 162.2,
      "sid": 79,
      "location": 2,
      "content": "多方合力之下",
      "music": 0.0
    },
    {
      "from": 162.2,
      "to": 164.64,
      "sid": 80,
      "location": 2,
      "content": "才能在水下待了近4年的制造业价格",
      "music": 0.0
    },
    {
      "from": 164.64,
      "to": 166.0,
      "sid": 81,
      "location": 2,
      "content": "重回了景气区间",
      "music": 0.0
    },
    {
      "from": 166.0,
      "to": 167.86,
      "sid": 82,
      "location": 2,
      "content": "但如果当前的PPPI的改善",
      "music": 0.0
    },
    {
      "from": 167.86,
      "to": 170.32,
      "sid": 83,
      "location": 2,
      "content": "仅仅是因为油价和有色一次性跳涨",
      "music": 0.0
    },
    {
      "from": 170.32,
      "to": 172.94,
      "sid": 84,
      "location": 2,
      "content": "那后续再通胀的持续性还是要打一个问号",
      "music": 0.0
    },
    {
      "from": 172.94,
      "to": 175.78,
      "sid": 85,
      "location": 2,
      "content": "那从这张反映制造业冷热的PMI数据图来看",
      "music": 0.0
    },
    {
      "from": 175.78,
      "to": 177.22,
      "sid": 86,
      "location": 2,
      "content": "目前呢相比2025年",
      "music": 0.0
    },
    {
      "from": 177.22,
      "to": 178.82,
      "sid": 87,
      "location": 2,
      "content": "除了原材料涨价之外",
      "music": 0.0
    },
    {
      "from": 178.82,
      "to": 181.9,
      "sid": 88,
      "location": 2,
      "content": "库存订单预期并未发生较大的变化",
      "music": 0.0
    },
    {
      "from": 181.9,
      "to": 183.86,
      "sid": 89,
      "location": 2,
      "content": "整体还是处于偏弱的状态",
      "music": 0.0
    },
    {
      "from": 183.86,
      "to": 186.0,
      "sid": 90,
      "location": 2,
      "content": "尤其是上游价格大幅上涨之下",
      "music": 0.0
    },
    {
      "from": 186.0,
      "to": 187.84,
      "sid": 91,
      "location": 2,
      "content": "企业的补库意愿呢相对不高",
      "music": 0.0
    },
    {
      "from": 187.84,
      "to": 190.42,
      "sid": 92,
      "location": 2,
      "content": "可以看到工业端对这次物价回暖呢",
      "music": 0.0
    },
    {
      "from": 190.42,
      "to": 191.24,
      "sid": 93,
      "location": 2,
      "content": "应该跟我一样",
      "music": 0.0
    },
    {
      "from": 191.24,
      "to": 192.9,
      "sid": 94,
      "location": 2,
      "content": "都还是保持着怀疑的态度",
      "music": 0.0
    },
    {
      "from": 192.9,
      "to": 196.28,
      "sid": 95,
      "location": 2,
      "content": "本月统计局呢公布了我国今年一季度的GDP数据",
      "music": 0.0
    },
    {
      "from": 196.28,
      "to": 197.68,
      "sid": 96,
      "location": 2,
      "content": "同比增长了5%",
      "music": 0.0
    },
    {
      "from": 197.68,
      "to": 200.16,
      "sid": 97,
      "location": 2,
      "content": "超过了今年5%左右的增长目标",
      "music": 0.0
    },
    {
      "from": 200.16,
      "to": 202.4,
      "sid": 98,
      "location": 2,
      "content": "近几年我国经济增长的动能呢",
      "music": 0.0
    },
    {
      "from": 202.4,
      "to": 204.82,
      "sid": 99,
      "location": 2,
      "content": "几乎都是呈现前高后低的现象",
      "music": 0.0
    },
    {
      "from": 204.82,
      "to": 205.98,
      "sid": 100,
      "location": 2,
      "content": "一季度增长最快",
      "music": 0.0
    },
    {
      "from": 205.98,
      "to": 206.72,
      "sid": 101,
      "location": 2,
      "content": "四季度最差",
      "music": 0.0
    },
    {
      "from": 206.72,
      "to": 208.14,
      "sid": 102,
      "location": 2,
      "content": "2024年的四季度反转",
      "music": 0.0
    },
    {
      "from": 208.14,
      "to": 210.12,
      "sid": 103,
      "location": 2,
      "content": "是得益于924的金融大放松",
      "music": 0.0
    },
    {
      "from": 210.12,
      "to": 211.94,
      "sid": 104,
      "location": 2,
