    },
    {
      "from": 21.28,
      "to": 23.9,
      "sid": 11,
      "location": 2,
      "content": "当然也包括集成电路价格的上涨",
      "music": 0.0
    },
    {
      "from": 23.9,
      "to": 26.96,
      "sid": 12,
      "location": 2,
      "content": "挤压了国内大模型厂商的企业利润",
      "music": 0.0
    },
    {
      "from": 26.96,
      "to": 29.88,
      "sid": 13,
      "location": 2,
      "content": "第二呢是ANTHROPIC的反蒸馏技术啊",
      "music": 0.0
    },
    {
      "from": 29.88,
      "to": 33.5,
      "sid": 14,
      "location": 2,
      "content": "也让国内的厂商在追赶方面有更大的困难",
      "music": 0.0
    },
    {
      "from": 33.5,
      "to": 35.76,
      "sid": 15,
      "location": 2,
      "content": "第三呢就是美国政府现在也下场了",
      "music": 0.0
    },
    {
      "from": 35.76,
      "to": 38.83,
      "sid": 16,
      "location": 2,
      "content": "对ANTHROPYS最新发布的FBO5",
