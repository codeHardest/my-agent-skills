    },
    {
      "from": 38.83,
      "to": 41.77,
      "sid": 17,
      "location": 2,
      "content": "这个新的大模型采取了出口管制措施",
      "music": 0.0
    },
    {
      "from": 41.77,
      "to": 43.89,
      "sid": 18,
      "location": 2,
      "content": "那综合这以上的原因呢",
