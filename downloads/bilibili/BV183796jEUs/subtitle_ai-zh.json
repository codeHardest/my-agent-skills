{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "v1.7.0.4",
  "body": [
    {
      "from": 0.04,
      "to": 3.46,
      "sid": 1,
      "location": 2,
      "content": "现在楼市最撕裂的一幕彻底的摆到了台面上",
      "music": 0.0
    },
    {
      "from": 3.46,
      "to": 4.7,
      "sid": 2,
      "location": 2,
      "content": "最近中金喊话",
      "music": 0.0
    },
    {
      "from": 4.7,
      "to": 5.78,
      "sid": 3,
      "location": 2,
      "content": "中国楼市啊",
      "music": 0.0
    },
    {
      "from": 5.78,
      "to": 6.5,
      "sid": 4,
      "location": 2,
      "content": "拐点一到",
      "music": 0.0
    },
    {
      "from": 6.5,
      "to": 7.84,
      "sid": 5,
      "location": 2,
      "content": "房价要回暖上涨",
      "music": 0.0
    },
    {
      "from": 7.84,
      "to": 9.16,
      "sid": 6,
      "location": 2,
      "content": "而另一边大摩表示",
      "music": 0.0
    },
    {
      "from": 9.16,
      "to": 11.22,
      "sid": 7,
      "location": 2,
      "content": "那今年楼市这一波只是短期反弹",
      "music": 0.0
    },
    {
      "from": 11.22,
      "to": 13.16,
      "sid": 8,
      "location": 2,
      "content": "那全国大盘根本没有见跌",
      "music": 0.0
    },
    {
      "from": 13.16,
      "to": 15.48,
      "sid": 9,
      "location": 2,
      "content": "那多数城市房价还是要继续调整",
      "music": 0.0
    },
    {
      "from": 15.48,
      "to": 17.08,
      "sid": 10,
      "location": 2,
      "content": "中金在最新的研报中",
      "music": 0.0
    },
    {
      "from": 17.08,
      "to": 18.9,
      "sid": 11,
      "location": 2,
      "content": "给出的判断是非常明确的哈",
      "music": 0.0
    },
    {
      "from": 18.9,
      "to": 20.82,
      "sid": 12,
      "location": 2,
      "content": "一线城市楼市的拐点已经确认",
      "music": 0.0
    },
    {
      "from": 20.82,
      "to": 23.0,
      "sid": 13,
      "location": 2,
      "content": "年内核心城市房价稳中有涨",
      "music": 0.0
    },
    {
      "from": 23.0,
      "to": 24.72,
      "sid": 14,
      "location": 2,
      "content": "楼市正式进入修复通道",
      "music": 0.0
    },
    {
      "from": 24.72,
      "to": 26.44,
      "sid": 15,
      "location": 2,
      "content": "那给出的理由主要有以下三个",
      "music": 0.0
    },
    {
      "from": 26.44,
      "to": 28.78,
      "sid": 16,
      "location": 2,
      "content": "一一线城市的基本面全面转好",
      "music": 0.0
    },
    {
      "from": 28.78,
      "to": 31.0,
      "sid": 17,
      "location": 2,
      "content": "北上广深近期的成交库存",
      "music": 0.0
    },
    {
      "from": 31.0,
      "to": 33.42,
      "sid": 18,
      "location": 2,
      "content": "房价三大核心数据全线走强",
      "music": 0.0
    },
    {
      "from": 33.42,
      "to": 37.26,
      "sid": 19,
      "location": 2,
      "content": "市场从之前的持续降温变成供需逐步偏紧",
      "music": 0.0
    },
    {
      "from": 37.26,
      "to": 38.72,
      "sid": 20,
      "location": 2,
      "content": "企稳信号非常明显",
      "music": 0.0
    },
    {
      "from": 38.72,
      "to": 43.24,
      "sid": 21,
      "location": 2,
      "content": "二是托底政策真正的这个见地落地见效",
      "music": 0.0
    },
    {
      "from": 43.24,
      "to": 44.56,
      "sid": 22,
      "location": 2,
      "content": "二手房收储",
      "music": 0.0
    },
    {
      "from": 44.56,
      "to": 46.66,
      "sid": 23,
      "location": 2,
      "content": "保障房再贷款两大政策落地",
      "music": 0.0
    },
    {
      "from": 46.66,
      "to": 50.42,
      "sid": 24,
      "location": 2,
      "content": "直接打通了楼市最重要的房置房屋置换链条啊",
      "music": 0.0
    },
    {
      "from": 50.42,
      "to": 53.64,
      "sid": 25,
      "location": 2,
      "content": "改善群体卖旧买新的流通性被激活",
      "music": 0.0
    },
    {
      "from": 53.64,
      "to": 56.74,
      "sid": 26,
      "location": 2,
      "content": "三是一线城市啊估值回归合理区间",
      "music": 0.0
    },
    {
      "from": 56.74,
      "to": 58.24,
      "sid": 27,
      "location": 2,
      "content": "经过多年的一个调整",
      "music": 0.0
    },
    {
      "from": 58.24,
      "to": 59.56,
      "sid": 28,
      "location": 2,
      "content": "核心城市的租售比",
      "music": 0.0
    },
    {
      "from": 59.56,
      "to": 61.94,
      "sid": 29,
      "location": 2,
      "content": "房价收入比慢慢回归健康区间",
      "music": 0.0
    },
    {
      "from": 61.94,
      "to": 64.5,
      "sid": 30,
      "location": 2,
      "content": "前期积压的刚需改善需求非常充足",
      "music": 0.0
    },
    {
      "from": 64.5,
      "to": 68.08,
      "sid": 31,
      "location": 2,
      "content": "二手房的回暖势头后续会稳步传导到新房市场",
      "music": 0.0
    },
    {
      "from": 68.08,
      "to": 70.52,
      "sid": 32,
      "location": 2,
      "content": "和中金的观点截然不同的是",
      "music": 0.0
    },
    {
      "from": 70.52,
      "to": 72.46,
      "sid": 33,
      "location": 2,
      "content": "大摩在研报中表示",
      "music": 0.0
    },
    {
      "from": 72.46,
      "to": 73.96,
      "sid": 34,
      "location": 2,
      "content": "34月份的楼市升温",
      "music": 0.0
    },
    {
      "from": 73.96,
      "to": 77.32,
      "sid": 35,
      "location": 2,
      "content": "只是积压需求集中释放的短期脉冲行情",
      "music": 0.0
    },
    {
      "from": 77.32,
      "to": 79.0,
      "sid": 36,
      "location": 2,
      "content": "根本不是趋势性反弹",
      "music": 0.0
    },
    {
      "from": 79.0,
      "to": 81.56,
      "sid": 37,
      "location": 2,
      "content": "全国楼市大盘依旧没有见底啊",
      "music": 0.0
    },
    {
      "from": 81.56,
      "to": 85.04,
      "sid": 38,
      "location": 2,
      "content": "多数城市房价销量后续仍然有调整压力",
      "music": 0.0
    },
    {
      "from": 85.04,
      "to": 85.94,
      "sid": 39,
      "location": 2,
      "content": "大范围回暖",
      "music": 0.0
    },
    {
      "from": 85.94,
      "to": 87.96,
      "sid": 40,
      "location": 2,
      "content": "最早也要等到2027年下半年",
      "music": 0.0
    },
    {
      "from": 87.96,
      "to": 89.22,
      "sid": 41,
      "location": 2,
      "content": "大摩给出的理由是",
      "music": 0.0
    },
    {
      "from": 89.22,
      "to": 92.4,
      "sid": 42,
      "location": 2,
      "content": "首先呢本轮呃楼市回暖没有购买力支撑",
      "music": 0.0
    },
    {
      "from": 92.4,
      "to": 94.44,
      "sid": 43,
      "location": 2,
      "content": "当下居民收入增速疲软啊",
      "music": 0.0
    },
    {
      "from": 94.44,
      "to": 96.03,
      "sid": 44,
      "location": 2,
      "content": "家庭房产杠杆偏高",
      "music": 0.0
    },
    {
      "from": 96.03,
      "to": 97.97,
      "sid": 45,
      "location": 2,
      "content": "船民购房的这个信心还是不足",
      "music": 0.0
    },
    {
      "from": 97.97,
      "to": 99.19,
      "sid": 46,
      "location": 2,
      "content": "短期的集中成交",
      "music": 0.0
    },
    {
      "from": 99.19,
      "to": 101.8,
      "sid": 47,
      "location": 2,
      "content": "只是把前期积压的需求给透支了哈",
      "music": 0.0
    },
    {
      "from": 101.8,
      "to": 104.22,
      "sid": 48,
      "location": 2,
      "content": "后续没有持续的接盘力量啊",
      "music": 0.0
    },
    {
      "from": 104.22,
      "to": 105.84,
      "sid": 49,
      "location": 2,
      "content": "行情就必然回落啊",
      "music": 0.0
    },
    {
      "from": 105.84,
      "to": 108.86,
      "sid": 50,
      "location": 2,
      "content": "其次就是全国二手房市场内卷依旧比较严重",
      "music": 0.0
    },
    {
      "from": 108.86,
      "to": 110.14,
      "sid": 51,
      "location": 2,
      "content": "那绝对的绝大多数城市",
      "music": 0.0
    },
    {
      "from": 110.14,
      "to": 111.94,
      "sid": 52,
      "location": 2,
      "content": "这个二手房的挂牌量还是居高不下",
      "music": 0.0
    },
    {
      "from": 111.94,
      "to": 114.24,
      "sid": 53,
      "location": 2,
      "content": "业主降价抛售还是常态",
      "music": 0.0
    },
    {
      "from": 114.24,
      "to": 116.29,
      "sid": 54,
      "location": 2,
      "content": "同时呃房租持续走低",
      "music": 0.0
    },
    {
      "from": 116.29,
      "to": 118.13,
      "sid": 55,
      "location": 2,
      "content": "充分说明市场供大于求",
      "music": 0.0
    },
    {
      "from": 118.13,
      "to": 119.11,
      "sid": 56,
      "location": 2,
      "content": "买房意愿薄弱",
      "music": 0.0
    },
    {
      "from": 119.11,
      "to": 121.16,
      "sid": 57,
      "location": 2,
      "content": "二手房只能靠降价抢客户",
      "music": 0.0
    },
    {
      "from": 121.16,
      "to": 122.62,
      "sid": 58,
      "location": 2,
      "content": "完全带不动新房去化",
      "music": 0.0
    },
    {
      "from": 122.62,
      "to": 124.4,
      "sid": 59,
      "location": 2,
      "content": "那整个置换链条根本跑不通",
      "music": 0.0
    },
    {
      "from": 124.4,
      "to": 126.12,
      "sid": 60,
      "location": 2,
      "content": "那最后就是政策只有口号",
      "music": 0.0
    },
    {
      "from": 126.12,
      "to": 127.12,
      "sid": 61,
      "location": 2,
      "content": "缺小落地",
      "music": 0.0
    },
    {
      "from": 127.12,
      "to": 129.32,
      "sid": 62,
      "location": 2,
      "content": "虽然各地纷纷出台二手房售出政策",
      "music": 0.0
    },
    {
      "from": 129.32,
      "to": 130.98,
      "sid": 63,
      "location": 2,
      "content": "但大多都停留在纸面",
      "music": 0.0
    },
    {
      "from": 130.98,
      "to": 132.92,
      "sid": 64,
      "location": 2,
      "content": "实际落地的体量极小啊",
      "music": 0.0
    },
    {
      "from": 132.92,
      "to": 134.98,
      "sid": 65,
      "location": 2,
      "content": "只能短暂安抚市场情绪",
      "music": 0.0
    },
    {
      "from": 134.98,
      "to": 137.4,
      "sid": 66,
      "location": 2,
      "content": "根本改变不了这个传播高库存",
      "music": 0.0
    },
    {
      "from": 137.4,
      "to": 139.3,
      "sid": 67,
      "location": 2,
      "content": "弱需求的这样的一个下行大势",
      "music": 0.0
    },
    {
      "from": 139.3,
      "to": 141.26,
      "sid": 68,
      "location": 2,
      "content": "其实看钟金和达摩的观点",
      "music": 0.0
    },
    {
      "from": 141.26,
      "to": 141.9,
      "sid": 69,
      "location": 2,
      "content": "你就会发现啊",
      "music": 0.0
    },
    {
      "from": 141.9,
      "to": 144.85,
      "sid": 70,
      "location": 2,
      "content": "他们说的观点并不是特别冲突啊",
      "music": 0.0
    },
    {
      "from": 144.85,
      "to": 146.95,
      "sid": 71,
      "location": 2,
      "content": "只是说一个是聚焦的核心城市",
      "music": 0.0
    },
    {
      "from": 146.95,
      "to": 148.61,
      "sid": 72,
      "location": 2,
      "content": "另一个聚焦的是全国楼市",
      "music": 0.0
    },
    {
      "from": 148.61,
      "to": 151.26,
      "sid": 73,
      "location": 2,
      "content": "两家机构看似在呃相互掐涨跌",
      "music": 0.0
    },
    {
      "from": 151.26,
      "to": 152.68,
      "sid": 74,
      "location": 2,
      "content": "但是真正分歧的核心",
      "music": 0.0
    },
    {
      "from": 152.68,
      "to": 155.96,
      "sid": 75,
      "location": 2,
      "content": "其实是对本轮楼市政策效力的一个判断",
      "music": 0.0
    },
    {
      "from": 155.96,
      "to": 157.3,
      "sid": 76,
      "location": 2,
      "content": "那中间认定啊",
      "music": 0.0
    },
    {
      "from": 157.3,
      "to": 159.76,
      "sid": 77,
      "location": 2,
      "content": "存量房收储叠加保障房再贷款落地",
      "music": 0.0
    },
    {
      "from": 159.76,
      "to": 162.16,
      "sid": 78,
      "location": 2,
      "content": "打通置换链条成为核心啊",
      "music": 0.0
    },
    {
      "from": 162.16,
      "to": 163.86,
      "sid": 79,
      "location": 2,
      "content": "城市企稳的一个关键啊",
      "music": 0.0
    },
    {
      "from": 163.86,
      "to": 164.76,
      "sid": 80,
      "location": 2,
      "content": "大摩则直言",
      "music": 0.0
    },
    {
      "from": 164.76,
      "to": 166.94,
      "sid": 81,
      "location": 2,
      "content": "各地收储的体量还是偏小哈",
      "music": 0.0
    },
    {
      "from": 166.94,
      "to": 168.42,
      "sid": 82,
      "location": 2,
      "content": "仅能够提振市场情绪",
      "music": 0.0
    },
    {
      "from": 168.42,
      "to": 170.06,
      "sid": 83,
      "location": 2,
      "content": "没办法从根本上扭转全国",
      "music": 0.0
    },
    {
      "from": 170.06,
      "to": 171.6,
      "sid": 84,
      "location": 2,
      "content": "房地产这样的下行的一个大势",
      "music": 0.0
    },
    {
      "from": 171.6,
      "to": 173.26,
      "sid": 85,
      "location": 2,
      "content": "不过就现在的房地产市场而言",
      "music": 0.0
    },
    {
      "from": 173.26,
      "to": 175.22,
      "sid": 86,
      "location": 2,
      "content": "接下来的6783个月",
      "music": 0.0
    },
    {
      "from": 175.22,
      "to": 177.06,
      "sid": 87,
      "location": 2,
      "content": "确实是今年楼市的一个分水岭",
      "music": 0.0
    },
    {
      "from": 177.06,
      "to": 179.8,
      "sid": 88,
      "location": 2,
      "content": "因为六到8月份本身就是楼市的一个传统淡季",
      "music": 0.0
    },
    {
      "from": 179.8,
      "to": 181.34,
      "sid": 89,
      "location": 2,
      "content": "如果在这个淡季里面",
      "music": 0.0
    },
    {
      "from": 181.34,
      "to": 184.38,
      "sid": 90,
      "location": 2,
      "content": "北上广深和强二线核心区域的这个成交量",
      "music": 0.0
    },
    {
      "from": 184.38,
      "to": 185.24,
      "sid": 91,
      "location": 2,
      "content": "还能够稳住",
      "music": 0.0
    },
    {
      "from": 185.24,
      "to": 186.62,
      "sid": 92,
      "location": 2,
      "content": "甚至是逆势上涨",
      "music": 0.0
    },
    {
      "from": 186.62,
      "to": 189.62,
      "sid": 93,
      "location": 2,
      "content": "那就说明这些地方的筑底信号已经非常明确了",
      "music": 0.0
    },
    {
      "from": 189.62,
      "to": 191.66,
      "sid": 94,
      "location": 2,
      "content": "市场预期就真的转过来了",
      "music": 0.0
    },
    {
      "from": 191.66,
      "to": 194.97,
      "sid": 95,
      "location": 2,
      "content": "但如果淡季已到的成交量立刻掉头向下了",
      "music": 0.0
    },
    {
      "from": 194.97,
      "to": 198.5,
      "sid": 96,
      "location": 2,
      "content": "那就说明这轮楼市回暖只是积压需求的一个啊",
      "music": 0.0
    },
    {
      "from": 198.5,
      "to": 199.06,
      "sid": 97,
      "location": 2,
      "content": "集中释放",
      "music": 0.0
    },
    {
      "from": 199.06,
      "to": 199.82,
      "sid": 98,
      "location": 2,
      "content": "透支完之后",
      "music": 0.0
    },
    {
      "from": 199.82,
      "to": 202.34,
      "sid": 99,
      "location": 2,
      "content": "市场又回到了原来那样的一个下行通道",
      "music": 0.0
    },
    {
      "from": 202.34,
      "to": 204.34,
      "sid": 100,
      "location": 2,
      "content": "不过大家也不用过度的悲观哈",
      "music": 0.0
    },
    {
      "from": 204.34,
      "to": 206.42,
      "sid": 101,
      "location": 2,
      "content": "哪怕下半年市场再次下沉",
      "music": 0.0
    },
    {
      "from": 206.42,
      "to": 208.1,
      "sid": 102,
      "location": 2,
      "content": "再次进行调整幅度",
      "music": 0.0
    },
    {
      "from": 208.1,
      "to": 210.02,
      "sid": 103,
      "location": 2,
      "content": "它也不会像前几年那么大了",
      "music": 0.0
    },
    {
      "from": 210.02,
      "to": 212.4,
      "sid": 104,
      "location": 2,
      "content": "毕竟我们已经调整了整整4年了",
      "music": 0.0
    },
    {
      "from": 212.4,
      "to": 215.42,
      "sid": 105,
      "location": 2,
