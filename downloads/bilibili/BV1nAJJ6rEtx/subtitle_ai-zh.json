{
  "font_size": 0.4,
  "font_color": "#FFFFFF",
  "background_alpha": 0.5,
  "background_color": "#9C27B0",
  "Stroke": "none",
  "type": "AIsubtitle",
  "lang": "zh",
  "version": "sync-v1.7.0.4",
  "body": [
    {
      "from": 0.14,
      "to": 4.6,
      "sid": 1,
      "location": 2,
      "content": "摩根士丹利最新的中国房地产市场研究报告显示",
      "music": 0.0
    },
    {
      "from": 4.6,
      "to": 7.8,
      "sid": 2,
      "location": 2,
      "content": "二手房销售出现了明显走弱的迹象",
      "music": 0.0
    },
    {
      "from": 7.8,
      "to": 10.72,
      "sid": 3,
      "location": 2,
      "content": "这份6月11日发布的报告显示",
      "music": 0.0
    },
    {
      "from": 10.72,
      "to": 12.15,
      "sid": 4,
      "location": 2,
      "content": "截至6月10日",
      "music": 0.0
    },
    {
      "from": 12.15,
      "to": 19.75,
      "sid": 5,
      "location": 2,
      "content": "25个重点城市的二手房实时销售同比增速已经放缓至九2%",
      "music": 0.0
    },
    {
      "from": 19.75,
      "to": 26.26,
      "sid": 6,
      "location": 2,
      "content": "这个数字相比4月份的30%和5月份的26%",
      "music": 0.0
    },
    {
      "from": 26.26,
      "to": 29.12,
      "sid": 7,
      "location": 2,
      "content": "可以说是断崖式下跌啊",
      "music": 0.0
    },
    {
      "from": 29.12,
      "to": 32.959,
      "sid": 8,
      "location": 2,
      "content": "确实这个数据的变化幅度相当惊人",
      "music": 0.0
    },
    {
      "from": 32.959,
      "to": 34.7,
      "sid": 9,
      "location": 2,
      "content": "更值得关注的是",
      "music": 0.0
    },
    {
      "from": 34.7,
      "to": 38.82,
      "sid": 10,
      "location": 2,
      "content": "尽管6月份有端午节假期带来的基数效应偏低",
      "music": 0.0
    },
    {
      "from": 38.82,
      "to": 42.3,
      "sid": 11,
      "location": 2,
      "content": "但销售仍然出现了如此大幅度的下滑",
      "music": 0.0
    },
    {
      "from": 42.3,
      "to": 46.02,
      "sid": 12,
      "location": 2,
      "content": "这说明市场降温不是季节性因素造成的",
      "music": 0.0
    },
    {
      "from": 46.02,
      "to": 48.58,
      "sid": 13,
      "location": 2,
      "content": "而是基本面出现了实质性变化",
      "music": 0.0
    },
    {
      "from": 48.58,
      "to": 53.26,
      "sid": 14,
      "location": 2,
      "content": "对而且这种回落趋势在不同城市的表现还不太一样",
      "music": 0.0
    },
    {
      "from": 53.26,
      "to": 55.4,
      "sid": 15,
      "location": 2,
      "content": "一线城市像南昌",
      "music": 0.0
    },
    {
      "from": 55.4,
      "to": 56.22,
      "sid": 16,
      "location": 2,
      "content": "佛山",
      "music": 0.0
    },
    {
      "from": 56.22,
      "to": 56.84,
      "sid": 17,
      "location": 2,
      "content": "南通",
      "music": 0.0
    },
    {
      "from": 56.84,
      "to": 59.18,
      "sid": 18,
      "location": 2,
      "content": "东莞这些地方的减速特别快",
      "music": 0.0
    },
    {
      "from": 59.18,
      "to": 60.84,
      "sid": 19,
      "location": 2,
      "content": "甚至有些二线城市",
      "music": 0.0
    },
    {
      "from": 60.84,
      "to": 62.58,
      "sid": 20,
      "location": 2,
      "content": "比如天津长沙",
      "music": 0.0
    },
    {
      "from": 62.58,
      "to": 65.48,
      "sid": 21,
      "location": 2,
      "content": "成都都出现了同比负增长",
      "music": 0.0
    },
    {
      "from": 65.48,
      "to": 69.11,
      "sid": 22,
      "location": 2,
      "content": "嗯这里面还有一个很重要的分化现象",
      "music": 0.0
    },
    {
      "from": 69.11,
      "to": 72.17,
      "sid": 23,
      "location": 2,
      "content": "在4月底政策放松的城市里",
      "music": 0.0
    },
    {
      "from": 72.17,
      "to": 75.65,
      "sid": 24,
      "location": 2,
      "content": "比如苏州和武汉销售表现依然比较强劲",
      "music": 0.0
    },
    {
      "from": 75.65,
      "to": 80.83,
      "sid": 25,
      "location": 2,
      "content": "但是广州深圳佛山这些地方却出现了两位数的同比下降",
      "music": 0.0
    },
    {
      "from": 80.83,
      "to": 85.14,
      "sid": 26,
      "location": 2,
      "content": "这反映出政策效果的持续性存在很大差异",
      "music": 0.0
    },
    {
      "from": 85.14,
      "to": 88.92,
      "sid": 27,
      "location": 2,
      "content": "其实摩根士丹利在之前的报告里就已经预测到",
      "music": 0.0
    },
    {
      "from": 88.92,
      "to": 91.75,
      "sid": 28,
      "location": 2,
      "content": "6月份同比增速会明显回落",
      "music": 0.0
    },
    {
      "from": 91.75,
      "to": 95.33,
      "sid": 29,
      "location": 2,
      "content": "还提到了三季度有可能转为同比负增长",
      "music": 0.0
    },
    {
      "from": 95.33,
      "to": 98.91,
      "sid": 30,
      "location": 2,
      "content": "现在看来他们的判断还是比较准确的",
      "music": 0.0
    },
    {
      "from": 98.91,
      "to": 100.95,
      "sid": 31,
      "location": 2,
      "content": "他们认为原因主要是两个",
      "music": 0.0
    },
    {
      "from": 100.95,
      "to": 103.58,
      "sid": 32,
      "location": 2,
      "content": "一是政策的刺激效果在减弱",
      "music": 0.0
    },
    {
      "from": 103.58,
      "to": 108.12,
      "sid": 33,
      "location": 2,
      "content": "二是去年四季度以来积压的需求已经释放的差不多了",
      "music": 0.0
    },
    {
      "from": 108.12,
      "to": 109.82,
      "sid": 34,
      "location": 2,
      "content": "这个分析很有道理",
      "music": 0.0
    },
    {
      "from": 109.82,
      "to": 111.7,
      "sid": 35,
      "location": 2,
      "content": "从政策效果来看",
      "music": 0.0
    },
    {
      "from": 111.7,
      "to": 115.42,
      "sid": 36,
      "location": 2,
      "content": "虽然去年下半年开始陆续出台了降低首付比例",
      "music": 0.0
    },
    {
      "from": 115.42,
      "to": 117.4,
      "sid": 37,
      "location": 2,
      "content": "放宽限购等措施",
      "music": 0.0
    },
    {
      "from": 117.4,
      "to": 122.34,
      "sid": 38,
      "location": 2,
      "content": "但这些措施对改善型需求的拉动作用正在边际递减",
      "music": 0.0
    },
    {
      "from": 122.34,
      "to": 123.7,
      "sid": 39,
      "location": 2,
      "content": "而从需求端看",
      "music": 0.0
    },
    {
      "from": 123.7,
      "to": 127.66,
      "sid": 40,
      "location": 2,
      "content": "居民收入预期和购房信心还没有完全恢复",
      "music": 0.0
    },
    {
      "from": 127.66,
      "to": 129.26,
      "sid": 41,
      "location": 2,
      "content": "大家还是在观望",
      "music": 0.0
    },
    {
      "from": 129.26,
      "to": 130.1,
      "sid": 42,
      "location": 2,
      "content": "说到政策",
      "music": 0.0
    },
    {
      "from": 130.1,
      "to": 132.34,
      "sid": 43,
      "location": 2,
      "content": "我觉得还有一个值得注意的点是",
      "music": 0.0
    },
    {
      "from": 132.34,
      "to": 135.61,
      "sid": 44,
      "location": 2,
      "content": "不同城市的应对策略差异很大",
      "music": 0.0
    },
    {
      "from": 135.61,
      "to": 139.21,
      "sid": 45,
      "location": 2,
      "content": "像苏州武汉这样反应快的城市",
      "music": 0.0
    },
    {
      "from": 139.21,
      "to": 141.61,
      "sid": 46,
      "location": 2,
      "content": "可能抓住了政策窗口期",
      "music": 0.0
    },
    {
      "from": 141.61,
      "to": 147.45,
      "sid": 47,
      "location": 2,
      "content": "而广州深圳这些一线城市可能还在权衡各种利弊",
      "music": 0.0
    },
    {
      "from": 147.45,
      "to": 151.69,
      "sid": 48,
      "location": 2,
      "content": "是的这种差异化政策执行其实是把双刃剑",
      "music": 0.0
    },
    {
      "from": 151.69,
      "to": 154.67,
      "sid": 49,
      "location": 2,
      "content": "一方面它给了地方政府一定的灵活性",
      "music": 0.0
    },
    {
      "from": 154.67,
      "to": 157.96,
      "sid": 50,
      "location": 2,
      "content": "但另一方面也容易造成市场预期混乱",
      "music": 0.0
    },
    {
      "from": 157.96,
      "to": 160.34,
      "sid": 51,
      "location": 2,
      "content": "购房者不知道政策会不会继续放松",
      "music": 0.0
    },
    {
      "from": 160.34,
      "to": 162.98,
      "sid": 52,
      "location": 2,
      "content": "开发商也不敢轻易调整定价策略",
      "music": 0.0
    },
    {
      "from": 162.98,
      "to": 166.56,
      "sid": 53,
      "location": 2,
      "content": "嗯所以摩根士丹利给出了一个比较谨慎的建议",
      "music": 0.0
    },
    {
      "from": 166.56,
      "to": 168.68,
      "sid": 54,
      "location": 2,
      "content": "要保持选择性投资",
      "music": 0.0
    },
    {
      "from": 168.68,
      "to": 170.84,
      "sid": 55,
      "location": 2,
      "content": "他们特别推荐了两家公司",
      "music": 0.0
    },
    {
      "from": 170.84,
      "to": 172.83,
      "sid": 56,
      "location": 2,
      "content": "一个是华润置地",
      "music": 0.0
    },
    {
      "from": 172.83,
      "to": 174.85,
      "sid": 57,
      "location": 2,
      "content": "一个是建发国际",
      "music": 0.0
    },
    {
      "from": 174.85,
      "to": 178.75,
      "sid": 58,
      "location": 2,
      "content": "这两家公司的共同特点是市盈率较低",
      "music": 0.0
    },
    {
      "from": 178.75,
      "to": 180.57,
      "sid": 59,
      "location": 2,
      "content": "股息收益率有吸引力",
      "music": 0.0
    },
    {
      "from": 180.57,
      "to": 184.27,
      "sid": 60,
      "location": 2,
      "content": "而且即使整个房地产物理市场没有明显复苏",
      "music": 0.0
    },
    {
      "from": 184.27,
      "to": 186.77,
      "sid": 61,
      "location": 2,
      "content": "他们也有一定的内生增长潜力",
      "music": 0.0
    },
    {
      "from": 186.77,
      "to": 189.94,
      "sid": 62,
      "location": 2,
      "content": "没错这两家公司的评级都是买入",
      "music": 0.0
    },
    {
      "from": 189.94,
      "to": 191.28,
      "sid": 63,
      "location": 2,
      "content": "但有趣的是",
      "music": 0.0
    },
    {
      "from": 191.28,
      "to": 196.1,
      "sid": 64,
      "location": 2,
      "content": "摩根士丹利并没有因为看好就给出过于乐观的价格目标",
      "music": 0.0
    },
    {
      "from": 199.37,
      "to": 202.49,
      "sid": 65,
      "location": 2,
      "content": "建发国际是32.59港元",
      "music": 0.0
    },
    {
      "from": 202.49,
      "to": 205.43,
      "sid": 66,
      "location": 2,
      "content": "这显示出他们对市场的谨慎态度",
      "music": 0.0
    },
    {
      "from": 205.43,
      "to": 206.47,
      "sid": 67,
      "location": 2,
      "content": "说到估值",
      "music": 0.0
    },
    {
      "from": 206.47,
      "to": 209.97,
      "sid": 68,
      "location": 2,
      "content": "我注意到报告中还提到了一个很有趣的观察",
      "music": 0.0
    },
    {
      "from": 209.97,
      "to": 213.53,
      "sid": 69,
      "location": 2,
      "content": "他们认为在2026年到2027年期间",
      "music": 0.0
    },
    {
      "from": 213.53,
      "to": 217.94,
      "sid": 70,
      "location": 2,
      "content": "房价可能会呈现一个普遍疲软的环比下降趋势",
      "music": 0.0
    },
    {
      "from": 217.94,
      "to": 222.26,
      "sid": 71,
      "location": 2,
      "content": "不过部分一线城市因为去库存进展较好",
      "music": 0.0
    },
    {
      "from": 222.26,
      "to": 224.65,
      "sid": 72,
      "location": 2,
      "content": "可能会出现轻微的环比上涨",
      "music": 0.0
    },
    {
      "from": 224.65,
      "to": 230.9,
      "sid": 73,
      "location": 2,
      "content": "这个判断其实体现了摩根士丹利对中国房地产市场结构性特征的把握",
      "music": 0.0
    },
    {
      "from": 230.9,
      "to": 234.38,
      "sid": 74,
      "location": 2,
      "content": "一线城市因为有更多的人口流入和政策支持",
      "music": 0.0
    },
    {
      "from": 234.38,
      "to": 235.98,
      "sid": 75,
      "location": 2,
      "content": "抗跌性相对较强",
      "music": 0.0
    },
    {
      "from": 235.98,
      "to": 238.58,
      "sid": 76,
      "location": 2,
      "content": "而三四线城市面临的压力可能更大",
      "music": 0.0
    },
    {
      "from": 238.58,
      "to": 241.28,
      "sid": 77,
      "location": 2,
      "content": "特别是那些产业基础薄弱",
      "music": 0.0
    },
    {
      "from": 241.28,
      "to": 243.5,
      "sid": 78,
      "location": 2,
      "content": "人口外流严重的地区",
      "music": 0.0
    },
    {
      "from": 243.5,
      "to": 245.26,
      "sid": 79,
      "location": 2,
      "content": "呃不过我想问一个问题",
      "music": 0.0
    },
    {
      "from": 245.26,
      "to": 247.32,
      "sid": 80,
      "location": 2,
      "content": "既然销售这么疲软",
      "music": 0.0
    },
    {
      "from": 247.32,
      "to": 251.26,
      "sid": 81,
      "location": 2,
      "content": "为什么摩根士丹利还是不太看好整个行业呢",
      "music": 0.0
    },
    {
      "from": 251.26,
      "to": 255.94,
      "sid": 82,
      "location": 2,
      "content": "毕竟股价从5月中旬到现在已经回调了18%了",
      "music": 0.0
    },
    {
      "from": 255.94,
      "to": 257.58,
      "sid": 83,
      "location": 2,
      "content": "这就是关键所在",
      "music": 0.0
    },
    {
      "from": 257.58,
      "to": 259.399,
      "sid": 84,
      "location": 2,
      "content": "虽然股价下跌了不少",
      "music": 0.0
    },
    {
      "from": 259.399,
      "to": 260.979,
      "sid": 85,
      "location": 2,
      "content": "但摩根士丹利认为",
      "music": 0.0
    },
    {
      "from": 260.979,
      "to": 263.799,
      "sid": 86,
      "location": 2,
      "content": "行业的基本面风险仍然大于机会",
      "music": 0.0
    },
    {
      "from": 263.799,
      "to": 264.63,
      "sid": 87,
      "location": 2,
      "content": "他们强调",
      "music": 0.0
    },
    {
      "from": 264.63,
      "to": 268.07,
      "sid": 88,
      "location": 2,
      "content": "3月份和4月份二手房销售的意外反弹",
      "music": 0.0
    },
    {
      "from": 268.07,
      "to": 273.22,
      "sid": 89,
      "location": 2,
      "content": "很大程度上是因为2025年第四季度积压的需求释放",
      "music": 0.0
    },
    {
      "from": 273.22,
      "to": 278.56,
      "sid": 90,
      "location": 2,
      "content": "以及限购限贷政策放松带来的短期刺激效应哦",
      "music": 0.0
    },
    {
      "from": 278.56,
      "to": 279.84,
      "sid": 91,
      "location": 2,
      "content": "也就是说",
      "music": 0.0
    },
    {
      "from": 279.84,
      "to": 283.84,
      "sid": 92,
      "location": 2,
      "content": "他们认为那两个月的回暖只是昙花一现",
      "music": 0.0
    },
    {
      "from": 283.84,
      "to": 285.07,
      "sid": 93,
      "location": 2,
      "content": "可以这么理解",
      "music": 0.0
    },
    {
      "from": 285.07,
      "to": 285.81,
      "sid": 94,
      "location": 2,
      "content": "他们认为",
      "music": 0.0
    },
    {
      "from": 285.81,
      "to": 287.73,
      "sid": 95,
      "location": 2,
      "content": "随着政策效应的消退",
      "music": 0.0
    },
    {
      "from": 287.73,
      "to": 290.11,
      "sid": 96,
      "location": 2,
      "content": "如果没有新的刺激措施出台",
      "music": 0.0
    },
    {
      "from": 290.11,
      "to": 293.01,
      "sid": 97,
      "location": 2,
      "content": "市场很可能会重回低迷状态",
      "music": 0.0
    },
    {
      "from": 293.01,
      "to": 296.71,
      "sid": 98,
      "location": 2,
      "content": "特别是在二手房供应量持续增加的情况下",
      "music": 0.0
    },
    {
      "from": 296.71,
      "to": 298.95,
      "sid": 99,
      "location": 2,
      "content": "价格下行的压力会比较大",
      "music": 0.0
    },
    {
      "from": 298.95,
      "to": 301.72,
      "sid": 100,
      "location": 2,
      "content": "嗯这就引出了一个很重要的问题",
      "music": 0.0
    },
    {
      "from": 301.72,
      "to": 303.48,
      "sid": 101,
      "location": 2,
      "content": "投资者应该如何应对",
      "music": 0.0
    },
    {
      "from": 303.48,
      "to": 306.26,
      "sid": 102,
      "location": 2,
      "content": "报告建议密切关注几个关键指标",
