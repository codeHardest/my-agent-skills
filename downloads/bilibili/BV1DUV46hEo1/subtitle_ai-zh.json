  "body": [
    {
      "from": 0.14,
      "to": 0.7,
      "sid": 1,
      "location": 2,
      "content": "朋友们",
      "music": 0.0
    },
    {
      "from": 0.7,
      "to": 1.72,
      "sid": 2,
      "location": 2,
      "content": "你们想过没有",
      "music": 0.0
    },
    {
      "from": 1.72,
      "to": 4.26,
      "sid": 3,
      "location": 2,
      "content": "一辆中国电动车在英国卖得挺火",
      "music": 0.0
    },
    {
      "from": 4.26,
      "to": 6.74,
      "sid": 4,
      "location": 2,
      "content": "结果下个月销量直接砍掉2/3",
      "music": 0.0
    },
    {
      "from": 6.74,
      "to": 7.54,
      "sid": 5,
      "location": 2,
      "content": "这是咋回事",
      "music": 0.0
    },
    {
      "from": 7.54,
      "to": 8.7,
      "sid": 6,
      "location": 2,
      "content": "这是出质量问题啦",
      "music": 0.0
    },
    {
      "from": 8.7,
      "to": 9.8,
      "sid": 7,
      "location": 2,
      "content": "还是口碑崩了",
      "music": 0.0
    },
    {
      "from": 9.8,
      "to": 11.21,
      "sid": 8,
      "location": 2,
      "content": "都不是人家",
      "music": 0.0
    },
    {
      "from": 11.21,
      "to": 13.14,
      "sid": 9,
      "location": 2,
      "content": "这叫正常化回调",
      "music": 0.0
    },
    {
      "from": 13.14,
      "to": 16.7,
      "sid": 10,
      "location": 2,
      "content": "这就是比亚迪今年4月在英国注册量",
      "music": 0.0
    },
    {
      "from": 16.7,
      "to": 18.06,
      "sid": 11,
      "location": 2,
      "content": "从3月的1万5000辆",
      "music": 0.0
    },
    {
      "from": 18.06,
      "to": 19.28,
      "sid": 12,
      "location": 2,
      "content": "直接掉到5000辆",
      "music": 0.0
    },
    {
      "from": 19.28,
      "to": 21.28,
      "sid": 13,
      "location": 2,
      "content": "把整体海外销量都拖累了",
      "music": 0.0
    },
    {
      "from": 21.28,
      "to": 23.77,
      "sid": 14,
      "location": 2,
      "content": "环比下滑了10%到15%嚯",
      "music": 0.0
    },
    {
      "from": 23.77,
      "to": 25.09,
      "sid": 15,
      "location": 2,
      "content": "这落差也太大了",
      "music": 0.0
    },
    {
      "from": 25.09,
      "to": 26.19,
      "sid": 16,
      "location": 2,
      "content": "更有意思的是",
      "music": 0.0
    },
    {
      "from": 26.19,
      "to": 30.4,
      "sid": 17,
      "location": 2,
      "content": "隔壁吉利在巴西单月销量暴涨210%",
      "music": 0.0
    },
    {
      "from": 30.4,
      "to": 32.68,
      "sid": 18,
      "location": 2,
      "content": "澳大利亚也猛增57%",
      "music": 0.0
    },
    {
      "from": 32.68,
      "to": 34.16,
      "sid": 19,
      "location": 2,
      "content": "成了头部车企里",
      "music": 0.0
    },
    {
      "from": 34.16,
      "to": 36.96,
      "sid": 20,
      "location": 2,
      "content": "唯一实现海外销量环比正增长的选手",
      "music": 0.0
    },
    {
      "from": 36.96,
      "to": 39.21,
      "sid": 21,
      "location": 2,
      "content": "这一冷一热反差够大的啊",
      "music": 0.0
    },
    {
      "from": 39.21,
      "to": 41.23,
      "sid": 22,
      "location": 2,
      "content": "这反差背后有啥门道",
      "music": 0.0
    },
    {
      "from": 41.23,
      "to": 43.63,
      "sid": 23,
      "location": 2,
      "content": "今天咱们就拆解大摩最新的研报",
      "music": 0.0
    },
    {
      "from": 43.63,
      "to": 45.27,
      "sid": 24,
      "location": 2,
      "content": "聊聊中国车企出海",
      "music": 0.0
    },
    {
      "from": 45.27,
      "to": 47.95,
      "sid": 25,
      "location": 2,
      "content": "在2026年4月的真实表现",
      "music": 0.0
    },
    {
      "from": 47.95,
      "to": 49.79,
      "sid": 26,
      "location": 2,
      "content": "还得是看数据说话",
      "music": 0.0
    },
    {
      "from": 49.79,
      "to": 51.15,
      "sid": 27,
      "location": 2,
      "content": "先看整体格局",
      "music": 0.0
    },
    {
      "from": 51.15,
      "to": 54.97,
      "sid": 28,
      "location": 2,
      "content": "现在这出海啊已经进入结构性分化阶段了",
      "music": 0.0
    },
    {
      "from": 54.97,
      "to": 55.67,
      "sid": 29,
      "location": 2,
      "content": "怎么个分化",
      "music": 0.0
    },
    {
      "from": 55.67,
      "to": 57.86,
      "sid": 30,
      "location": 2,
      "content": "法吉利那是本月的优等生",
      "music": 0.0
    },
    {
      "from": 57.86,
      "to": 60.68,
      "sid": 31,
      "location": 2,
      "content": "海外销量环比增长10%到15%",
      "music": 0.0
    },
    {
      "from": 60.68,
      "to": 62.8,
      "sid": 32,
      "location": 2,
      "content": "全靠巴西和澳洲发力",
      "music": 0.0
    },
    {
      "from": 62.8,
      "to": 63.6,
      "sid": 33,
      "location": 2,
      "content": "那比亚迪呢",
      "music": 0.0
    },
    {
      "from": 63.6,
      "to": 65.4,
      "sid": 34,
      "location": 2,
      "content": "比亚迪虽然环比下滑",
      "music": 0.0
    },
    {
      "from": 65.4,
      "to": 68.259,
      "sid": 35,
      "location": 2,
      "content": "但那是英国高基术后的自然回落",
      "music": 0.0
    },
    {
      "from": 68.259,
      "to": 70.159,
      "sid": 36,
      "location": 2,
      "content": "他在巴西澳洲",
      "music": 0.0
    },
    {
      "from": 70.159,
      "to": 71.579,
      "sid": 37,
      "location": 2,
      "content": "印尼这三个市场",
      "music": 0.0
    },
    {
      "from": 71.579,
      "to": 74.219,
      "sid": 38,
      "location": 2,
      "content": "合计贡献了44%的海外销量",
      "music": 0.0
    },
    {
      "from": 74.219,
      "to": 76.399,
      "sid": 39,
      "location": 2,
      "content": "而且全部跑赢当地大盘",
      "music": 0.0
    },
    {
      "from": 76.399,
      "to": 77.49,
      "sid": 40,
      "location": 2,
      "content": "那是真厉害",
      "music": 0.0
    },
    {
      "from": 77.49,
      "to": 79.27,
      "sid": 41,
      "location": 2,
      "content": "长城就有小幅回调",
      "music": 0.0
    },
    {
      "from": 79.27,
      "to": 81.33,
      "sid": 42,
      "location": 2,
      "content": "主要被澳大利亚和巴西拖累了",
      "music": 0.0
    },
    {
      "from": 81.33,
      "to": 83.69,
      "sid": 43,
      "location": 2,
      "content": "不过人家在俄罗斯市场稳如泰山",
      "music": 0.0
    },
    {
      "from": 83.69,
      "to": 85.23,
      "sid": 44,
      "location": 2,
      "content": "基本盘那是杠杠的",
      "music": 0.0
    },
    {
      "from": 85.23,
      "to": 86.39,
      "sid": 45,
      "location": 2,
      "content": "说到跑赢大盘",
      "music": 0.0
    },
    {
      "from": 86.39,
      "to": 87.91,
      "sid": 46,
      "location": 2,
      "content": "这个细节特别值得玩味",
      "music": 0.0
    },
    {
      "from": 87.91,
      "to": 91.85,
      "sid": 47,
      "location": 2,
      "content": "你看巴西整个汽车市场4月环比跌了9%",
      "music": 0.0
    },
    {
      "from": 91.85,
      "to": 93.07,
      "sid": 48,
      "location": 2,
      "content": "这环境够差了吧",
      "music": 0.0
    },
    {
      "from": 93.07,
      "to": 94.259,
      "sid": 49,
      "location": 2,
      "content": "确实不咋地",
      "music": 0.0
    },
    {
      "from": 94.259,
      "to": 97.199,
      "sid": 50,
      "location": 2,
      "content": "但比亚迪销量反而增长12%",
      "music": 0.0
    },
    {
      "from": 97.199,
      "to": 98.75,
      "sid": 51,
      "location": 2,
      "content": "达到1万8000辆",
