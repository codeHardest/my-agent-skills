    },
    {
      "from": 192.95,
      "to": 194.93,
      "sid": 100,
      "location": 2,
      "content": "同比仍高出22%",
      "music": 0.0
    },
    {
      "from": 194.93,
      "to": 195.83,
      "sid": 101,
      "location": 2,
      "content": "那就是说",
