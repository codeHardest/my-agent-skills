    },
    {
      "from": 98.75,
      "to": 99.95,
      "sid": 52,
      "location": 2,
      "content": "吉利更夸张",
      "music": 0.0
    },
    {
      "from": 99.95,
      "to": 101.69,
      "sid": 53,
      "location": 2,
      "content": "直接干到3600辆",
      "music": 0.0
    },
    {
      "from": 101.69,
      "to": 103.99,
      "sid": 54,
      "location": 2,
      "content": "环比暴涨210%",
      "music": 0.0
    },
    {
      "from": 103.99,
      "to": 104.75,
      "sid": 55,
      "location": 2,
      "content": "好家伙",
      "music": 0.0
    },
    {
      "from": 104.75,
      "to": 106.27,
      "sid": 56,
      "location": 2,
      "content": "这是逆势狂奔呐",
      "music": 0.0
    },
    {
      "from": 106.27,
      "to": 107.39,
      "sid": 57,
      "location": 2,
      "content": "这说明啥",
      "music": 0.0
    },
    {
      "from": 107.39,
      "to": 108.81,
      "sid": 58,
      "location": 2,
      "content": "不是市场变好了",
      "music": 0.0
    },
    {
      "from": 108.81,
      "to": 111.29,
      "sid": 59,
      "location": 2,
      "content": "是中国品牌正在抢份额",
      "music": 0.0
    },
    {
      "from": 111.29,
      "to": 112.57,
      "sid": 60,
      "location": 2,
      "content": "澳大利亚也一样",
      "music": 0.0
    },
    {
      "from": 112.57,
      "to": 114.37,
      "sid": 61,
      "location": 2,
      "content": "整体车市下滑9%",
      "music": 0.0
    },
    {
      "from": 114.37,
      "to": 117.09,
      "sid": 62,
      "location": 2,
      "content": "比亚迪和吉利却分别逆势增长",
      "music": 0.0
    },
    {
      "from": 117.09,
      "to": 118.77,
      "sid": 63,
      "location": 2,
      "content": "9%和57%",
      "music": 0.0
    },
    {
      "from": 118.77,
      "to": 120.24,
      "sid": 64,
      "location": 2,
      "content": "这哪是便宜替代",
      "music": 0.0
    },
    {
      "from": 120.24,
      "to": 121.56,
      "sid": 65,
      "location": 2,
      "content": "这是真被认可了",
      "music": 0.0
    },
    {
      "from": 121.56,
      "to": 122.98,
      "sid": 66,
      "location": 2,
      "content": "不过咱也得看看风险",
      "music": 0.0
    },
    {
      "from": 122.98,
      "to": 124.71,
      "sid": 67,
      "location": 2,
      "content": "就是区域依赖度",
      "music": 0.0
    },
    {
      "from": 124.71,
      "to": 126.11,
      "sid": 68,
      "location": 2,
      "content": "这确实得注意",
      "music": 0.0
    },
    {
      "from": 126.11,
      "to": 127.75,
      "sid": 69,
      "location": 2,
      "content": "吉利的海外销量里",
      "music": 0.0
    },
    {
      "from": 127.75,
      "to": 128.45,
      "sid": 70,
      "location": 2,
      "content": "俄罗斯",
      "music": 0.0
    },
    {
      "from": 128.45,
      "to": 129.19,
      "sid": 71,
      "location": 2,
      "content": "墨西哥",
      "music": 0.0
    },
    {
      "from": 129.19,
      "to": 129.81,
      "sid": 72,
      "location": 2,
      "content": "巴西",
      "music": 0.0
    },
    {
      "from": 129.81,
      "to": 132.579,
      "sid": 73,
      "location": 2,
      "content": "澳大利亚四个国家就占了63%",
